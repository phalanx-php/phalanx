includes:
    - packages/phalanx-phpstan/extension.neon

parameters:
    level: 8
    # OSR-40 root gate: keep current OpenSwoole foundation packages green.
    # Legacy and parallel-lane packages are classified in vault context and
    # reintroduced package-by-package as their 0.2 ports land.
    paths:
        - packages/phalanx-aegis/src
        - packages/phalanx-archon/src
        - packages/phalanx-argos/src
        - packages/phalanx-athena/src
        - packages/phalanx-cli/src
        - packages/phalanx-eidolon/src
        - packages/phalanx-enigma/src
        - packages/phalanx-grammata/src
        - packages/phalanx-hermes/src
        - packages/phalanx-hydra/src
        - packages/phalanx-iris/src
        - packages/phalanx-phpstan/src
        - packages/phalanx-skopos/src
        - packages/phalanx-stoa/src
        - packages/phalanx-surreal/src
        - packages/phalanx-styx/src
        - demos
    scanDirectories:
        - vendor/openswoole/ide-helper
    phalanxInternalPaths:
        - packages/phalanx-aegis/src/Concurrency/Co.php
        - packages/phalanx-aegis/src/Cancellation/CancellationToken.php
        - packages/phalanx-aegis/src/Pool/ObjectPool.php
        - packages/phalanx-aegis/src/Pool/PoolRing.php
        - packages/phalanx-aegis/src/Runtime/CoroutineRuntime.php
        - packages/phalanx-aegis/src/Runtime/RuntimeHooks.php
        - packages/phalanx-aegis/src/Scope/ExecutionLifecycleScope.php
        - packages/phalanx-aegis/src/Scope/TransactionLifecycleScope.php
        - packages/phalanx-aegis/src/Service/LazySingleton.php
        - packages/phalanx-aegis/src/Support/ExecutionScopeDelegate.php
        - packages/phalanx-aegis/src/Supervisor/InProcessLedger.php
        - packages/phalanx-aegis/src/Supervisor/LedgerStorage.php
        - packages/phalanx-aegis/src/Supervisor/Supervisor.php
        - packages/phalanx-aegis/src/Supervisor/SwooleTableLedger.php
        - packages/phalanx-aegis/src/Supervisor/TaskRun.php
        - packages/phalanx-aegis/src/Worker/
        - packages/phalanx-stoa/src/StoaRunner.php
    phalanxEnforcedPaths:
        - packages/phalanx-aegis/src
        - packages/phalanx-archon/src
        - packages/phalanx-athena/src
        - packages/phalanx-enigma/src
        - packages/phalanx-hermes/src
        - packages/phalanx-hydra/src
        - packages/phalanx-iris/src
        - packages/phalanx-phpstan/src
        - packages/phalanx-skopos/src
        - packages/phalanx-stoa/src
        - packages/phalanx-surreal/src
        - packages/phalanx-styx/src
    phalanxAuditPaths: []
    phalanxRuntimeHookInternalPaths:
        - packages/phalanx-aegis/src/Runtime/RuntimeHookNames.php
        - packages/phalanx-aegis/src/Runtime/RuntimeHooks.php
        - packages/phalanx-aegis/src/Runtime/RuntimePolicy.php
    phalanxProcessInternalPaths:
        - packages/phalanx-aegis/src/System/Internal/SymfonyProcessAdapter.php
        - packages/phalanx-hydra/src/WorkerPool/WorkerPool.php
    phalanxCoroutineInternalPaths:
        - packages/phalanx-aegis/src/Scope/ExecutionLifecycleScope.php
    excludePaths:
        analyseAndScan:
            - packages/phalanx-athena/src/Cli/AgentRepl.php
    ignoreErrors:
        -
            identifier: callable.nonCallable
            reportUnmatched: true
    tmpDir: .phpstan-cache
    treatPhpDocTypesAsCertain: false
    bootstrapFiles: []
