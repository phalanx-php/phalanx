includes:
    - framework/src/PHPStan/extension.neon

parameters:
    level: 8
    # OSR-40 root gate: keep current OpenSwoole foundation packages green.
    # Legacy and parallel-lane packages are classified in vault context and
    # reintroduced package-by-package as their 0.2 ports land.
    paths:
        - framework/src/Aegis/src
        - framework/src/Archon/src
        - framework/src/Argos/src
        - framework/src/Athena/src
        - framework/src/Cli/src
        - framework/src/Eidolon/src
        - framework/src/Enigma/src
        - framework/src/Grammata/src
        - framework/src/Hermes/src
        - framework/src/Hydra/src
        - framework/src/Iris/src
        - framework/src/Panoply/src
        - framework/src/PHPStan/src
        - framework/src/Skopos/src
        - framework/src/Stoa/src
        - framework/src/Surreal/src
        - framework/src/Theatron/src
        - framework/src/Styx/src
        - benchmarks
        - demos
    scanDirectories:
        - vendor/openswoole/ide-helper
    phalanxInternalPaths:
        - framework/src/Aegis/src/Concurrency/Co.php
        - framework/src/Aegis/src/Cancellation/CancellationToken.php
        - framework/src/Aegis/src/Pool/ObjectPool.php
        - framework/src/Aegis/src/Pool/PoolRing.php
        - framework/src/Aegis/src/Runtime/CoroutineRuntime.php
        - framework/src/Aegis/src/Runtime/RuntimeHooks.php
        - framework/src/Aegis/src/Scope/BorrowedScopeFrame.php
        - framework/src/Aegis/src/Scope/ExecutionLifecycleScope.php
        - framework/src/Aegis/src/Scope/TransactionLifecycleScope.php
        - framework/src/Aegis/src/Service/LazySingleton.php
        - framework/src/Aegis/src/Support/ExecutionScopeDelegate.php
        - framework/src/Aegis/src/Supervisor/InProcessLedger.php
        - framework/src/Aegis/src/Supervisor/LedgerStorage.php
        - framework/src/Aegis/src/Supervisor/Supervisor.php
        - framework/src/Aegis/src/Supervisor/SwooleTableLedger.php
        - framework/src/Aegis/src/Supervisor/TaskRun.php
        - framework/src/Aegis/src/Worker/
        - framework/src/Stoa/src/StoaRunner.php
    phalanxEnforcedPaths:
        - framework/src/Aegis/src
        - framework/src/Archon/src
        - framework/src/Athena/src
        - framework/src/Enigma/src
        - framework/src/Grammata/src
        - framework/src/Hermes/src
        - framework/src/Hydra/src
        - framework/src/Iris/src
        - framework/src/PHPStan/src
        - framework/src/Skopos/src
        - framework/src/Stoa/src
        - framework/src/Surreal/src
        - framework/src/Styx/src
    phalanxAuditPaths: []
    phalanxRuntimeHookInternalPaths:
        - framework/src/Aegis/src/Runtime/RuntimeCapability.php
        - framework/src/Aegis/src/Runtime/RuntimeHookNames.php
        - framework/src/Aegis/src/Runtime/RuntimeHooks.php
        - framework/src/Aegis/src/Runtime/RuntimePolicy.php
    phalanxProcessInternalPaths:
        - framework/src/Aegis/src/System/Internal/SymfonyProcessAdapter.php
        - framework/src/Hydra/src/WorkerPool/WorkerPool.php
    phalanxCoroutineInternalPaths:
        - framework/src/Aegis/src/Scope/ExecutionLifecycleScope.php
        - benchmarks/kernel/cases/ContextSwitchCases.php
    ignoreErrors:
        -
            identifier: phalanx.testing.useBenchmarkHarness
            path: benchmarks/http/cases/StoaCases.php
            reportUnmatched: true
        -
            identifier: phalanx.testing.useBenchmarkHarness
            path: benchmarks/http/server.php
            reportUnmatched: true
    tmpDir: .phpstan-cache
    treatPhpDocTypesAsCertain: false
    bootstrapFiles: []
