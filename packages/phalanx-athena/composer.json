{
    "name": "phalanx-php/athena",
    "description": "AI agent runtime for Phalanx — providers, tools, streaming, structured output, multi-agent coordination",
    "license": "MIT",
    "type": "library",
    "keywords": ["ai", "agent", "llm", "claude", "openai", "ollama", "streaming", "tools", "async"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-athena",
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.6",
        "phalanx-php/iris": "^0.6",
        "phalanx-php/styx": "^0.5"
    },
    "suggest": {
        "phalanx-php/redis": "For conversation memory and pub/sub agent coordination",
        "phalanx-php/postgres": "For persistent conversation storage and LISTEN/NOTIFY tasks",
        "phalanx-php/hermes": "For real-time agent sessions over WebSocket",
        "phalanx-php/archon": "For CLI agent REPL",
        "guzzlehttp/guzzle": "For Guzzle-based SDKs (AWS, Stripe) via CoroutineGuzzleStack",
        "hyperf/guzzle": "Coroutine-aware Guzzle handler so blocking SDKs cooperate with the OpenSwoole reactor"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Athena\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Athena\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "demo": ["@demo:streaming", "@demo:guzzle"],
        "demo:streaming": "php examples/01-streaming-providers/demo.php",
        "demo:guzzle": "php examples/02-guzzle-sdk-coexistence/demo.php",
        "demo:serve:support-triage": "php examples/support-triage/server.php",
        "demo:serve:research-agent": "php examples/research-agent/server.php",
        "demo:serve:fleet-gateway": "php examples/multi-tenant-fleet/gateway.php",
        "demo:worker:fleet": "php examples/multi-tenant-fleet/worker.php"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
