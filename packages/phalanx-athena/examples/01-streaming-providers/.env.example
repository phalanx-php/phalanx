# Athena Streaming Providers demo
#
# Live mode: set to 1 to enable cloud-provider keys below.
# Without it, only local Ollama is attempted (auto-detected).
ATHENA_DEMO_LIVE=0

# Cloud providers (require ATHENA_DEMO_LIVE=1)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=

# Local Ollama (auto-detected when Ollama is running on localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_ENABLED=
