{
    "name": "havy/http",
    "description": "HTTP server framework for Convoy",
    "license": "MIT",
    "type": "library",
    "keywords": ["http", "server", "routing", "async", "fastroute", "reactphp"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "homepage": "https://github.com/havy-tech/convoy-http",
    "require": {
        "php": "^8.4",
        "havy/core": "^1.0",
        "nikic/fast-route": "^2.0",
        "react/datagram": "^1.10",
        "react/http": "^1.10"
    },
    "suggest": {
        "symfony/runtime": "For Symfony Runtime integration via ConvoyHttpRunner",
        "havy/stream": "For streaming responses",
        "havy/parallel": "For worker process parallelism in request handlers"
    },
    "autoload": {
        "psr-4": {
            "Convoy\\Http\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Convoy\\Http\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
