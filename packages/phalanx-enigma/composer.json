{
    "name": "phalanx-php/enigma",
    "description": "Non-blocking SSH command execution, file transfer, and tunnel management as Phalanx tasks",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phalanx-php/phalanx-enigma",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.5",
        "phalanx-php/grammata": "^0.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Enigma\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Enigma\\Tests\\": "tests/"
        }
    }
}
