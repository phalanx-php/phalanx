{
    "name": "phalanx/filesystem",
    "description": "Async-aware filesystem operations for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": ["filesystem", "async", "file", "stream", "reactphp"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "homepage": "https://github.com/havy-tech/phalanx-filesystem",
    "require": {
        "php": "^8.4",
        "phalanx/core": "^0.5",
        "react/stream": "^1.4"
    },
    "suggest": {
        "phalanx/parallel": "Required for WorkerReadFile/WorkerWriteFile (slow-storage offload)"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Filesystem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Filesystem\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.5-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
