#!/usr/bin/env php
<?php

declare(strict_types=1);

namespace Phalanx\Skopos;

use Phalanx\Cancellation\Cancelled;

(static function (): never {
    $autoloadCandidates = [
        __DIR__ . '/../vendor/autoload.php',
        __DIR__ . '/../../../vendor/autoload.php',
        __DIR__ . '/../../../../vendor/autoload.php',
    ];

    $autoloaded = false;

    foreach ($autoloadCandidates as $file) {
        if (file_exists($file)) {
            require $file;
            $autoloaded = true;
            break;
        }
    }

    if (!$autoloaded) {
        fwrite(STDERR, "Could not find autoload.php. Run 'composer install' first.\n");
        exit(1);
    }

    $configFile = getcwd() . '/skopos.php';

    if (!file_exists($configFile)) {
        fwrite(STDERR, "No skopos.php found in " . getcwd() . "\n");
        fwrite(STDERR, "Create a skopos.php that returns a " . SkoposApplicationBuilder::class . " from Skopos::starting().\n");
        exit(1);
    }

    $result = require $configFile;

    if (!$result instanceof SkoposApplicationBuilder) {
        fwrite(STDERR, "skopos.php must return an instance of " . SkoposApplicationBuilder::class . "\n");
        exit(1);
    }

    try {
        exit($result->run());
    } catch (Cancelled) {
        exit(130);
    }
})();
