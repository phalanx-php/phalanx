{
    "name": "phalanx/skopos",
    "description": "Dev server orchestrator with process management, output multiplexing, and file watching",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phalanx-php/phalanx-skopos",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "phalanx/aegis": "^0.5",
        "phalanx/styx": "^0.5",
        "react/child-process": "^0.6",
        "react/http": "^1.10",
        "react/socket": "^1.16"
    },
    "bin": ["bin/skopos"],
    "autoload": {
        "psr-4": {
            "Phalanx\\Skopos\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
