{
    "name": "phalanx-php/skopos",
    "description": "Dev server orchestrator with process management, output multiplexing, and file watching",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/phalanx-php/phalanx-skopos",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-openswoole": "^26.0",
        "phalanx-php/aegis": "^0.6"
    },
    "bin": ["bin/skopos"],
    "autoload": {
        "psr-4": {
            "Phalanx\\Skopos\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
