{
    "name": "phalanx-php/surreal",
    "description": "SurrealDB RPC and live-query client for Phalanx using Iris, Hermes, and Aegis runtime supervision",
    "license": "MIT",
    "type": "library",
    "keywords": ["surrealdb", "phalanx", "aegis", "iris", "http", "rpc"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-surreal",
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.6",
        "phalanx-php/hermes": "^0.6",
        "phalanx-php/iris": "^0.6"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Surreal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Surreal\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "demo": ["@demo:memory", "@demo:live"],
        "demo:memory": "php examples/01-in-memory-rpc/demo.php",
        "demo:live": "php examples/02-live-query/demo.php"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
