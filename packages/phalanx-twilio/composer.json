{
    "name": "phalanx/twilio",
    "description": "Twilio integration for Phalanx — async SMS, voice, TwiML, and Conversation Relay",
    "license": "MIT",
    "type": "library",
    "keywords": ["twilio", "sms", "voice", "twiml", "conversation-relay", "async"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "homepage": "https://github.com/havy-tech/phalanx-twilio",
    "require": {
        "php": "^8.4",
        "phalanx/core": "^0.4",
        "react/http": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Twilio\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Twilio\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.4-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
