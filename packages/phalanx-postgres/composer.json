{
    "name": "phalanx/postgres",
    "description": "Async PostgreSQL for Phalanx via amphp/postgres",
    "license": "MIT",
    "type": "library",
    "keywords": ["postgres", "async", "database", "amphp", "pool", "reactphp"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "homepage": "https://github.com/havy-tech/phalanx-postgres",
    "require": {
        "php": "^8.4",
        "phalanx/core": "^1.0",
        "phalanx/stream": "^1.0",
        "amphp/postgres": "^2.2",
        "revolt/event-loop-adapter-react": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Postgres\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Postgres\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
