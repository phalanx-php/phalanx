{
    "name": "havy/parallel",
    "description": "Worker process parallelism for Convoy",
    "license": "MIT",
    "type": "library",
    "keywords": ["parallel", "worker", "process", "async", "ipc", "reactphp"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "homepage": "https://github.com/havy-tech/convoy-parallel",
    "require": {
        "php": "^8.4",
        "havy/core": "^1.0",
        "react/child-process": "^0.6",
        "react/async": "^4.3",
        "react/event-loop": "^1.5",
        "react/promise": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "Convoy\\Parallel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Convoy\\Parallel\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/convoy-worker"
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
