{
    "name": "phalanx/ai",
    "description": "AI agent runtime for Phalanx — providers, tools, streaming, structured output, multi-agent coordination",
    "license": "MIT",
    "type": "library",
    "keywords": ["ai", "agent", "llm", "claude", "openai", "ollama", "streaming", "tools", "async"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "homepage": "https://github.com/havy-tech/phalanx-ai",
    "require": {
        "php": "^8.4",
        "phalanx/core": "^1.0",
        "phalanx/stream": "^1.0",
        "phalanx/http": "^1.0"
    },
    "suggest": {
        "phalanx/redis": "For conversation memory and pub/sub agent coordination",
        "phalanx/postgres": "For persistent conversation storage and LISTEN/NOTIFY tasks",
        "phalanx/ws-server": "For real-time agent sessions over WebSocket",
        "phalanx/console": "For CLI agent REPL"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Ai\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Ai\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
