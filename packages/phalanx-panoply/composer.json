{
  "name": "phalanx-php/panoply",
  "description": "Agent abstraction for PHP 8.4+: contracts, provider/transport adapters, conversation parsers, vendor HomeDirs",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "agents",
    "llm",
    "anthropic",
    "openai",
    "gemini",
    "ollama",
    "agent-abstraction",
    "conversation-parser",
    "openswoole"
  ],
  "homepage": "https://github.com/phalanx-php/phalanx-panoply",
  "authors": [
    {
      "name": "Jonathan Havens",
      "email": "mail@phalanx-php.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "phalanx-php/aegis": "^0.2",
    "phalanx-php/athena": "^0.2",
    "phalanx-php/iris": "^0.2",
    "symfony/uid": "^7.0 || ^8.0",
    "symfony/yaml": "^7.0 || ^8.0"
  },
  "require-dev": {
    "openswoole/ide-helper": "^26.2",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^13.0",
    "rector/rector": "^2.0",
    "slevomat/coding-standard": "^8.15",
    "squizlabs/php_codesniffer": "^3.10 || ^4.0"
  },
  "suggest": {
    "ext-sqlite3": "Required for Codex HomeDir sqlite-backed history",
    "ext-openswoole": "Required for the Iris transport and Aegis runtime"
  },
  "scripts": {
    "rector": "rector process",
    "rector:dry": "rector process --dry-run",
    "cs": "phpcs",
    "cs:fix": "phpcbf",
    "test": "php vendor/bin/phpunit"
  },
  "autoload": {
    "psr-4": {
      "Phalanx\\Panoply\\": "src/Panoply/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Phalanx\\Panoply\\Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.2.x-dev"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
