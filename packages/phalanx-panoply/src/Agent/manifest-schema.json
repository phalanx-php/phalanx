{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Panoply Agent Manifest",
    "description": "Schema for phalanx-panoply agent manifest YAML files loaded by Agent\\Loader\\Manifest.",
    "type": "object",
    "additionalProperties": false,
    "required": ["agents"],
    "properties": {
        "agents": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["class"],
                "properties": {
                    "class": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Fully-qualified class name of an Agent implementation."
                    }
                }
            }
        }
    }
}
