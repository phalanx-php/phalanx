{
    "name": "convoy/postgres",
    "description": "Async PostgreSQL for Convoy via amphp/postgres",
    "license": "MIT",
    "type": "library",
    "keywords": ["postgres", "async", "database", "amphp", "pool", "reactphp"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "homepage": "https://github.com/havy-tech/convoy-postgres",
    "require": {
        "php": "^8.4",
        "convoy/core": "^1.0",
        "convoy/stream": "^1.0",
        "amphp/postgres": "^2.2",
        "revolt/event-loop-adapter-react": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Convoy\\Postgres\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Convoy\\Postgres\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
