{
  "name": "phalanx-php/aegis",
  "description": "Managed async for PHP 8.4+ on OpenSwoole",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "async",
    "concurrency",
    "coroutines",
    "openswoole",
    "supervisor",
    "parallel",
    "structured-concurrency"
  ],
  "homepage": "https://github.com/phalanx-php/phalanx-aegis",
  "authors": [
    {
      "name": "Jonathan Havens",
      "email": "mail@phalanx-php.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-openswoole": "^26.2",
    "openswoole/core": "^26.2",
    "symfony/uid": "^7.0"
  },
  "require-dev": {
    "phalanx-php/archon": "^0.5",
    "phalanx-php/stoa": "^0.5",
    "phalanx-php/hydra": "^0.5",
    "openswoole/ide-helper": "^26.2",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0",
    "rector/rector": "^2.0",
    "slevomat/coding-standard": "^8.15",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "scripts": {
    "demo": ["@demo:runtime", "@demo:supervision", "@demo:cancellation", "@demo:singleflight", "@demo:memory"],
    "demo:runtime": "php examples/01-runtime-policy/demo.php",
    "demo:supervision": "php examples/02-scope-supervision/demo.php",
    "demo:cancellation": "php examples/03-cancellation/demo.php",
    "demo:singleflight": "php examples/04-singleflight/demo.php",
    "demo:memory": "php examples/05-runtime-memory/demo.php",
    "rector": "rector process",
    "rector:dry": "rector process --dry-run",
    "cs": "phpcs",
    "cs:fix": "phpcbf",
    "test": "php vendor/bin/phpunit"
  },
  "suggest": {
    "phalanx-php/styx": "Reactive stream primitives (Emitter, ScopedStream, Channel)",
    "phalanx-php/archon": "CLI application framework",
    "phalanx-php/stoa": "HTTP server framework",
    "phalanx-php/hydra": "Worker process parallelism",
    "spatie/backtrace": "Enhanced stack traces",
    "symfony/runtime": "For symfony/runtime integration",
    "symfony/dotenv": "For .env file support"
  },
  "autoload": {
    "psr-4": {
      "Phalanx\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Phalanx\\Tests\\": "tests/"
    },
    "classmap": [
      "tests/Support/Fixtures/"
    ]
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.5.x-dev"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
