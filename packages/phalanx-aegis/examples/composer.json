{
    "name": "phalanx-php/aegis-examples",
    "description": "Runnable Phalanx Aegis demos",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../*"
        }
    ],
    "scripts": {
        "demo": ["@demo:runtime", "@demo:supervision", "@demo:cancellation", "@demo:singleflight"],
        "demo:runtime": "php 01-runtime-policy/demo.php",
        "demo:supervision": "php 02-scope-supervision/demo.php",
        "demo:cancellation": "php 03-cancellation/demo.php",
        "demo:singleflight": "php 04-singleflight/demo.php"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
