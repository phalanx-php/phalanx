{
    "name": "convoy/integrations",
    "description": "AI and Twilio integrations for Convoy",
    "license": "MIT",
    "type": "library",
    "keywords": ["ai", "claude", "openai", "twilio", "sms", "voice", "integration", "async"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "homepage": "https://github.com/havy-tech/convoy-integrations",
    "require": {
        "php": "^8.4",
        "convoy/core": "^1.0",
        "convoy/stream": "^1.0",
        "react/http": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Convoy\\Integration\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Convoy\\Integration\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
