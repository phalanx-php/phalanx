{
    "name": "phalanx-php/phpstan",
    "description": "PHPStan safety rules for Phalanx concurrent and parallel PHP",
    "license": "MIT",
    "type": "phpstan-extension",
    "require": {
        "php": "^8.4",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\PHPStan\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        },
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
