# Stoa 03-realtime demo environment
# The listen address is taken from $argv[1] or chosen randomly — no required variables.

# Optional: application environment
# APP_ENV=dev
# APP_DEBUG=1

# Optional: Phalanx server config (applied via AppContext when no explicit listen() call overrides)
# PHALANX_HOST=127.0.0.1
# PHALANX_PORT=8080
# PHALANX_REQUEST_TIMEOUT=30
# PHALANX_DRAIN_TIMEOUT=30
# PHALANX_DEBUG=false
# PHALANX_QUIET=false
