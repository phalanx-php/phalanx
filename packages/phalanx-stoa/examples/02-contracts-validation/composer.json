{
    "name": "phalanx-php/example-stoa-contracts-validation",
    "description": "Phalanx Stoa example: DTO hydration, headers, validation, and param policies",
    "type": "project",
    "require": {
        "php": "^8.4",
        "phalanx-php/stoa": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../../*"
        }
    ],
    "autoload": {
        "psr-4": {
            "Acme\\StoaDemo\\Contracts\\": "src/"
        }
    },
    "scripts": {
        "demo": "php demo.php",
        "serve": "php server.php"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
