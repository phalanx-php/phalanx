{
    "name": "phalanx-php/example-stoa-advanced-api",
    "description": "Phalanx Stoa example: mounted route groups, middleware, auth, services, and OpenAPI",
    "type": "project",
    "require": {
        "php": "^8.4",
        "phalanx-php/stoa": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../../*"
        }
    ],
    "autoload": {
        "psr-4": {
            "Acme\\StoaDemo\\Advanced\\": "src/"
        }
    },
    "scripts": {
        "demo": "php demo.php",
        "serve": "php server.php"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
