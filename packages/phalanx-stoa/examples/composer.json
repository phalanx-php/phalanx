{
    "name": "phalanx-php/stoa-examples",
    "description": "Runnable Phalanx Stoa demos",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.4",
        "phalanx-php/stoa": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../*"
        }
    ],
    "autoload": {
        "psr-4": {
            "Acme\\StoaDemo\\Advanced\\": "03-advanced-api/src/",
            "Acme\\StoaDemo\\Basic\\": "01-basic-routing/src/",
            "Acme\\StoaDemo\\Contracts\\": "02-contracts-validation/src/"
        }
    },
    "scripts": {
        "demo": ["@demo:basic", "@demo:contracts", "@demo:advanced"],
        "demo:basic": "php 01-basic-routing/demo.php",
        "demo:contracts": "php 02-contracts-validation/demo.php",
        "demo:advanced": "php 03-advanced-api/demo.php",
        "serve:basic": "php 01-basic-routing/server.php",
        "serve:contracts": "php 02-contracts-validation/server.php",
        "serve:advanced": "php 03-advanced-api/server.php"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
