{
    "name": "phalanx-php/stoa",
    "description": "HTTP server framework for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": ["http", "server", "routing", "async", "fastroute", "openswoole"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-stoa",
    "require": {
        "php": "^8.4",
        "guzzlehttp/psr7": "^2.0",
        "nikic/fast-route": "^2.0",
        "openswoole/core": "^26.2",
        "phalanx-php/aegis": "^0.5"
    },
    "suggest": {
        "symfony/runtime": "For Symfony Runtime integration via PhalanxHttpRunner",
        "phalanx-php/styx": "For streaming responses",
        "phalanx-php/hydra": "For worker process parallelism in request handlers"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Stoa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Tests\\Stoa\\": "tests/"
        }
    },
    "scripts": {
        "demo": ["@demo:basic", "@demo:contracts", "@demo:advanced"],
        "demo:basic": "php examples/01-basic-routing/demo.php",
        "demo:contracts": "php examples/02-contracts-validation/demo.php",
        "demo:advanced": "php examples/03-advanced-api/demo.php",
        "demo:serve:basic": "php examples/01-basic-routing/server.php",
        "demo:serve:contracts": "php examples/02-contracts-validation/server.php",
        "demo:serve:advanced": "php examples/03-advanced-api/server.php"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.5-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
