{
    "name": "phalanx-php/stoa",
    "description": "HTTP server framework for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": ["http", "server", "routing", "async", "fastroute", "openswoole"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-stoa",
    "require": {
        "php": "^8.4",
        "guzzlehttp/psr7": "^2.0",
        "nikic/fast-route": "^2.0",
        "openswoole/core": "^26.2",
        "phalanx-php/aegis": "^0.5"
    },
    "suggest": {
        "symfony/runtime": "For Symfony Runtime integration via Stoa::starting()",
        "phalanx-php/hydra": "For worker process parallelism in request handlers"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Stoa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Tests\\Stoa\\": "tests/"
        }
    },
    "scripts": {
        "demo": ["@demo:quickstart", "@demo:api", "@demo:realtime", "@demo:runtime"],
        "demo:quickstart": "php examples/01-basic-routing/demo.php",
        "demo:api": "php examples/02-api/demo.php",
        "demo:realtime": "php examples/03-realtime/demo.php",
        "demo:runtime": "php examples/04-runtime-lifecycle/demo.php",
        "demo:serve:quickstart": "php examples/01-basic-routing/server.php",
        "demo:serve:api": "php examples/02-api/server.php",
        "demo:serve:realtime": "php examples/03-realtime/server.php",
        "demo:serve:runtime": "php examples/04-runtime-lifecycle/server.php"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.5-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
