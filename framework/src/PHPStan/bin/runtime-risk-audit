#!/usr/bin/env php
<?php

declare(strict_types=1);

use Phalanx\PHPStan\Audit\RuntimeRiskScanner;

$autoload = null;
$autoloadCandidates = [
    __DIR__ . '/../../../../vendor/autoload.php',
    __DIR__ . '/../vendor/autoload.php',
];

foreach ($autoloadCandidates as $candidate) {
    if (is_file($candidate)) {
        $autoload = $candidate;
        break;
    }
}

if ($autoload === null) {
    fwrite(STDERR, "Cannot find autoload.php\n");
    exit(1);
}

require $autoload;

$paths = array_values(array_slice($argv, 1));
if ($paths === []) {
    $paths = ['framework/src', 'composer.json', 'composer.lock'];
}

$risks = (new RuntimeRiskScanner())->scanPaths($paths);
foreach ($risks as $risk) {
    printf(
        "%s\t%s:%d\t%s\n",
        $risk->category,
        $risk->file,
        $risk->line,
        $risk->symbol,
    );
}

printf("runtime-risk-audit: %d finding(s)\n", count($risks));
