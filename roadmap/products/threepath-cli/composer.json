{
    "name": "phalanx-php/threepath-cli",
    "description": "ThreePath/Inverto STB control CLI built on Phalanx",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "dev-main",
        "phalanx-php/archon": "dev-main",
        "phalanx-php/argos": "dev-main",
        "react/datagram": "^1.10",
        "symfony/runtime": "^7.2",
        "react/promise-timer": "^1.11"
    },
    "bin": ["bin/threepath"],
    "autoload": {
        "psr-4": {
            "ThreePath\\": "src/ThreePath/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThreePath\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:stb": "phpunit --group stb"
    },
    "extra": {
        "runtime": {
            "class": "ThreePath\\ConsoleRuntime"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../phalanx/packages/*"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    }
}
