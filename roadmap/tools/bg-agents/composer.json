{
    "name": "phalanx-php/bg-agents",
    "description": "Phalanx-native background specialist mesh on top of daemon8",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "@dev",
        "phalanx-php/archon": "@dev",
        "phalanx-php/athena": "@dev",
        "phalanx-php/grammata": "@dev",
        "phalanx-php/styx": "@dev",
        "react/http": "^1.10",
        "symfony/runtime": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/yaml": "^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "bin": ["bin/bg-agents"],
    "autoload": {
        "psr-4": {
            "BgAgents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BgAgents\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../phalanx/packages/*"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "runtime": {
            "class": "BgAgents\\ConsoleRuntime"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=512M",
        "test": "phpunit",
        "lint": "find bin src tests -name '*.php' -exec php -l {} \\; | grep -v 'No syntax errors'"
    }
}
