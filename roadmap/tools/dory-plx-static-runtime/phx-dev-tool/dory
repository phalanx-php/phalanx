#!/bin/bash

# dory - Phalanx Developer Tool
# This script manages the Phalanx runtime and project commands.

set -e

DORY_DIR="$HOME/.dory"
RUNTIME_VERSION="8.4.21-openswoole-26.2.0"
RUNTIME_PATH="$DORY_DIR/runtime/$RUNTIME_VERSION/php"

# Ensure runtime is available
if [ ! -f "$RUNTIME_PATH" ]; then
    echo "Phalanx runtime not found. Initializing..."
    mkdir -p "$(dirname "$RUNTIME_PATH")"

    # In a real scenario, we would download it.
    # For this PoC, we'll copy the one we built.
    SOURCE_RUNTIME="${PHALANX_ROOT:-$PWD}/buildroot/bin/php"
    SOURCE_SFX="${PHALANX_ROOT:-$PWD}/buildroot/bin/micro.sfx"
    if [ -f "$SOURCE_RUNTIME" ]; then
        cp "$SOURCE_RUNTIME" "$RUNTIME_PATH"
        chmod +x "$RUNTIME_PATH"
        cp "$SOURCE_SFX" "$(dirname "$RUNTIME_PATH")/micro.sfx"
        echo "Runtime and micro.sfx installed to $(dirname "$RUNTIME_PATH")"
    else
        echo "Error: Source runtime not found at $SOURCE_RUNTIME"
        exit 1
    fi
fi

# Compatibility layer path
COMPAT_LAYER="${PHALANX_ROOT:-$PWD}/poc/phx-dev-tool/compat.php"

# Run the command
# We use -d auto_prepend_file to inject our compatibility layer automatically
# so the user code doesn't need to know about it.
"$RUNTIME_PATH" -d phar.readonly=0 -d auto_prepend_file="$COMPAT_LAYER" "${PHALANX_ROOT:-$PWD}/poc/phx-dev-tool/bin/dory.php" "$@"
