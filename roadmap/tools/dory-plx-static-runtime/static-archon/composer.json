{
    "name": "phalanx-poc/static-archon",
    "type": "project",
    "require": {
        "php": "^8.4",
        "phalanx-php/archon": "@dev",
        "phalanx-php/aegis": "@dev",
        "symfony/runtime": "^7.0",
        "openswoole/core": "^26.2"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../phalanx/packages/phalanx-archon"
        },
        {
            "type": "path",
            "url": "../../phalanx/packages/phalanx-aegis"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
