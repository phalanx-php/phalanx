parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        analyseAndScan:
            - vendor/*
    tmpDir: .phpstan-cache
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Scopeable and Executable are marker interfaces; impls always declare __invoke.
        - identifier: callable.nonCallable
        # ext-openswoole stubs not present in dev (composer ignored the platform req).
        -
            identifier: class.notFound
            message: '#(Swoole|OpenSwoole)\\#'
        - '#Constant SWOOLE_HOOK_ALL not found#'
        - '#Static method (Swoole|OpenSwoole)\\.*::.*\(\) invoked with .* parameter.*, .* required#'
        # service<T>() generic flow can't be statically tracked through `class-string<T>` callers.
        - identifier: argument.templateType
        - identifier: generics.objectAlwaysSatisfied
        # Coroutine-spawn closures populate by-reference arrays; phpstan can't track through Coroutine::create.
        - '#Empty array passed to foreach#'
        - '#Parameter \#1 \$type of method AegisSwoole\\Scope\\Scope::service\(\) expects class-string<object>, string given#'
        - '#Parameter \#1 \$type of method AegisSwoole\\Service\\LazySingleton::get\(\) expects class-string<object>, string given#'
        - '#Property AegisSwoole\\Scope\\ExecutionLifecycleScope::\$scopedCreationOrder#'
        - '#Method AegisSwoole\\Scope\\ExecutionLifecycleScope::service\(\) should return T of object but returns object#'
        - '#Property AegisSwoole\\Scope\\ExecutionLifecycleScope::\$scopedInstances#'
        - '#Property AegisSwoole\\ApplicationBuilder::\$providers#'
        - '#Property AegisSwoole\\Cancellation\\CancellationToken::\$timerId#'
        - '#Property AegisSwoole\\Concurrency\\RetryPolicy::\$retryOn#'
        - '#Property AegisSwoole\\Service\\LazySingleton::\$instances#'
        - '#Property AegisSwoole\\Service\\LazySingleton::\$creationOrder#'
        - '#Property AegisSwoole\\Service\\ServiceCatalog::\$configs#'
        - '#Get hook for property AegisSwoole\\Concurrency\\SettlementBag::\$errors#'
        - '#Using nullsafe property access#'
        - '#Invalid type Throwable\|null to throw#'
