{
    "name": "phalanx-php/redis",
    "description": "Native Redis client for Phalanx using ext-redis and Aegis managed pooling",
    "license": "MIT",
    "type": "library",
    "keywords": ["redis", "openswoole", "phalanx", "aegis", "pubsub", "cache"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-redis",
    "require": {
        "php": "^8.4",
        "ext-redis": "*",
        "phalanx-php/aegis": "^0.6",
        "phalanx-php/styx": "^0.6"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Redis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Redis\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
