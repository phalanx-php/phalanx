{
    "name": "phalanx-php/eidolon",
    "description": "Frontend bridge for Phalanx - typed route contracts, OpenAPI generation, Kubb integration, and signal-based reactivity",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "frontend",
        "openapi",
        "kubb",
        "tanstack",
        "ssr",
        "signals",
        "async",
        "openswoole"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-eidolon",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.6",
        "phalanx-php/stoa": "^0.6",
        "phalanx-php/styx": "^0.6"
    },
    "suggest": {
        "phalanx-php/hermes": "For WebSocket signal transport",
        "phalanx-php/athena": "For agent streaming to frontend"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml.dist"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Eidolon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Eidolon\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
