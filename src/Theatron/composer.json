{
    "name": "phalanx-php/theatron",
    "description": "Async terminal UI framework for Phalanx PHP",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.4",
        "ext-openswoole": "^26.2",
        "ext-pcntl": "*",
        "ext-mbstring": "*",
        "phalanx-php/aegis": "^0.6",
        "phalanx-php/archon": "^0.6",
        "phalanx-php/athena": "^0.6",
        "phalanx-php/hermes": "^0.6",
        "phalanx-php/hydra": "^0.6",
        "phalanx-php/iris": "^0.6",
        "phalanx-php/panoply": "^0.6",
        "phalanx-php/stoa": "^0.6",
        "phalanx-php/surreal": "^0.6",
        "phalanx-php/styx": "^0.6",
        "league/commonmark": "^2.7",
        "symfony/runtime": "^7.0",
        "symfony/dotenv": "^7.0"
    },
    "bin": [
        "bin/theatron"
    ],
    "scripts": {
        "test": "php -d memory_limit=512M ../../vendor/bin/phpunit -c phpunit.xml"
    },
    "autoload": {
        "files": [
            "src/Ui/functions.php"
        ],
        "psr-4": {
            "Phalanx\\Theatron\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Theatron\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "slevomat/coding-standard": "*",
        "squizlabs/php_codesniffer": "*",
        "rector/rector": "^2.4",
        "rector/swiss-knife": "^2.3",
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.0"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    }
}
