#!/usr/bin/env php
<?php

declare(strict_types=1);

use Phalanx\Testing\Codegen\AccessorTraitWriter;
use Phalanx\Testing\Codegen\LensDiscovery;

require __DIR__ . '/accessor-common.php';

$bundles = collectBundles($rootDir, $moduleDir, $frameworkDir);
$lenses = (new LensDiscovery())->discover($bundles);
$target = is_dir($frameworkDir)
    ? $frameworkDir . '/Runtime/src/Testing/Generated/TestAppAccessors.php'
    : $moduleDir . '/src/Testing/Generated/TestAppAccessors.php';

(new AccessorTraitWriter())->write($lenses, $target);

printf("Wrote %d accessor(s) to %s\n", count($lenses), $target);
