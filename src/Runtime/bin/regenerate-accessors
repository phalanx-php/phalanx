#!/usr/bin/env php
<?php

declare(strict_types=1);

use Phalanx\Testing\Codegen\AccessorTraitWriter;
use Phalanx\Testing\Codegen\LensDiscovery;

$autoloadCandidates = [
    $_composer_autoload_path ?? null,
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../vendor/autoload.php',
];

foreach ($autoloadCandidates as $candidate) {
    if (is_string($candidate) && is_file($candidate)) {
        require $candidate;
        break;
    }
}

if (!class_exists(LensDiscovery::class)) {
    fwrite(STDERR, "Composer autoloader not found. Run `composer install` from the framework root.\n");
    exit(1);
}

$rootDir = realpath(__DIR__ . '/../../..') ?: realpath(__DIR__ . '/..');
if ($rootDir === false) {
    fwrite(STDERR, "Cannot resolve project root.\n");
    exit(1);
}

$moduleDir = realpath(__DIR__ . '/..');
if ($moduleDir === false) {
    fwrite(STDERR, "Cannot resolve Runtime module root.\n");
    exit(1);
}

$frameworkDir = $rootDir . '/src';
$bundles = collectBundles($rootDir, $moduleDir, $frameworkDir);
$lenses = (new LensDiscovery())->discover($bundles);
$target = is_dir($frameworkDir)
    ? $frameworkDir . '/Runtime/src/Testing/Generated/TestAppAccessors.php'
    : $moduleDir . '/src/Testing/Generated/TestAppAccessors.php';

(new AccessorTraitWriter())->write($lenses, $target);

printf("Wrote %d accessor(s) to %s\n", count($lenses), $target);

/**
 * @return list<class-string<\Phalanx\Testing\TestableBundle>>
 */
function collectBundles(string $rootDir, string $moduleDir, string $frameworkDir): array
{
    $sources = is_dir($frameworkDir)
        ? [$rootDir . '/composer.json']
        : [$moduleDir . '/composer.json'];

    if (is_dir($frameworkDir)) {
        foreach (glob($frameworkDir . '/*/composer.json') ?: [] as $moduleJson) {
            $sources[] = $moduleJson;
        }
    }

    $bundles = [];

    foreach ($sources as $source) {
        $contents = @file_get_contents($source);
        if ($contents === false) {
            continue;
        }

        $data = json_decode($contents, true);
        if (!is_array($data)) {
            continue;
        }

        $declared = $data['extra']['phalanx']['bundles'] ?? null;
        if (!is_array($declared)) {
            continue;
        }

        foreach ($declared as $bundleClass) {
            if (is_string($bundleClass)) {
                $bundles[] = $bundleClass;
            }
        }
    }

    return array_values(array_unique($bundles));
}
