{
    "name": "phalanx-php/argos",
    "description": "Network discovery, probing, and device management for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "network",
        "discovery",
        "mdns",
        "ssdp",
        "wol",
        "ping",
        "scan",
        "async",
        "openswoole"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-argos",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-openswoole": "*",
        "phalanx-php/aegis": "^0.6",
        "mlocati/ip-lib": "^1.22"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Argos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Argos\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
