{
    "name": "phalanx-php/enigma",
    "description": "Non-blocking SSH command execution, file transfer, and tunnel management as Phalanx tasks",
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/phalanx-php/phalanx-enigma",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.6",
        "phalanx-php/grammata": "^0.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml.dist"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Enigma\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Enigma\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
