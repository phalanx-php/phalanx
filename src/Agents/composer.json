{
    "name": "phalanx-php/agents",
    "description": "Agents activity runtime for Phalanx - supervised turns, effects, grants, hooks, and AiProviders invocation loops",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "ai",
        "agent",
        "llm",
        "activity",
        "effects",
        "grants",
        "ai-providers",
        "streaming",
        "tools",
        "async"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-agents",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "support": {
        "source": "https://github.com/phalanx-php/phalanx-agents"
    },
    "require": {
        "php": "^8.4",
        "phalanx-php/runtime": "^0.7",
        "phalanx-php/http-client": "^0.7",
        "phalanx-php/ai-providers": "^0.7",
        "phalanx-php/stream": "^0.7",
        "phalanx-php/surrealdb": "^0.7",
        "symfony/uid": "^7.0 || ^8.0"
    },
    "suggest": {
        "phalanx-php/console": "CLI agent commands via Console command lifecycle",
        "phalanx-php/websocket": "Real-time agent sessions over WebSocket",
        "phalanx-php/tui": "Tui Runtime workspace rendering for agent work and review state"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.env*",
            "/**/.env*",
            "/.gitattributes",
            "/.github",
            "/.github/**",
            "/.gitignore",
            "/**/.gitignore",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml.dist"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Agents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Agents\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.7.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
