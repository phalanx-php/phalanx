{
    "name": "phalanx-php/iris",
    "description": "Outbound HTTP client for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "http",
        "client",
        "outbound",
        "openswoole"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-iris",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "openswoole/core": "^26.2",
        "phalanx-php/aegis": "^0.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml.dist"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Iris\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Iris\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
