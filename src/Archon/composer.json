{
    "name": "phalanx-php/archon",
    "description": "CLI application framework for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "cli",
        "console",
        "async",
        "phalanx"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-archon",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "support": {
        "source": "https://github.com/phalanx-php/phalanx-archon"
    },
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.6"
    },
    "suggest": {
        "symfony/runtime": "For Symfony Runtime integration via Archon::starting()",
        "phalanx-php/styx": "For streaming data through console commands",
        "phalanx-php/hydra": "For worker process parallelism in CLI tasks"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.env*",
            "/**/.env*",
            "/.gitattributes",
            "/.github",
            "/.github/**",
            "/.gitignore",
            "/**/.gitignore",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Archon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Archon\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        },
        "phalanx": {
            "bundles": [
                "Phalanx\\Archon\\Testing\\ArchonTestableBundle"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
