{
    "name": "phalanx-php/cli",
    "description": "Phalanx CLI: doctor, OpenSwoole installer using PIE, and project scaffolding",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "cli",
        "phalanx",
        "openswoole",
        "installer",
        "doctor"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-cli",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "symfony/console": "^7.4 || ^8.0",
        "symfony/process": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "bin": [
        "bin/phalanx"
    ],
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.github",
            "/.github/**",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml.dist"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Cli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Cli\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
