{
    "name": "phalanx-php/hydra",
    "description": "Worker process parallelism for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "parallel",
        "worker",
        "process",
        "ipc",
        "openswoole"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-hydra",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "phalanx-php/aegis": "^0.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "bin": [
        "bin/phalanx-worker"
    ],
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Hydra\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Hydra\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
