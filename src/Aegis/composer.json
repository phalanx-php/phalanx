{
    "name": "phalanx-php/aegis",
    "description": "Managed async for PHP 8.4+ on Swoole",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "async",
        "concurrency",
        "coroutines",
        "swoole",
        "supervisor",
        "parallel",
        "structured-concurrency"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-aegis",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-openswoole": "^26.2",
        "openswoole/core": "^26.2",
        "phalanx-php/themis": "^0.6",
        "symfony/process": "^7.0 || ^8.0",
        "symfony/uid": "^7.0 || ^8.0"
    },
    "suggest": {
        "phalanx-php/styx": "Reactive stream primitives (Emitter, ScopedStream, Channel)",
        "phalanx-php/archon": "CLI application framework",
        "phalanx-php/stoa": "HTTP server framework",
        "phalanx-php/hydra": "Worker process parallelism",
        "spatie/backtrace": "Enhanced stack traces",
        "symfony/runtime": "For symfony/runtime integration",
        "symfony/dotenv": "For .env file support"
    },
    "require-dev": {
        "phalanx-php/archon": "^0.6",
        "phalanx-php/stoa": "^0.6",
        "phalanx-php/hydra": "^0.6",
        "openswoole/ide-helper": "^26.2",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.0",
        "slevomat/coding-standard": "^8.15",
        "squizlabs/php_codesniffer": "^3.10 || ^4.0"
    },
    "bin": [
        "bin/regenerate-accessors",
        "bin/check-accessors-in-sync"
    ],
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.github",
            "/.github/**",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml.dist"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Aegis\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Support/Fixtures/"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
