parameters:
    phalanxInternalPaths: []
    phalanxEnforcedPaths: []
    phalanxAuditPaths: []
    phalanxRuntimeHookInternalPaths: []
    phalanxLifecycleInternalPaths: []
    phalanxProcessInternalPaths: []
    phalanxCoroutineInternalPaths: []
    phalanxTestingPaths: []
    phalanxTestingUseTestAppExemptPaths: []
    phalanxTestingUseTestScopeExemptPaths: []
    phalanxTestingNoRawSleepExemptPaths: []
    phalanxTestingLensRequiresBundleExemptPaths: []
    phalanxTestingDirectTestAppApplicationExemptPaths: []
    phalanxRuntimeNativeLensClasses:
        - Phalanx\Testing\Lenses\ConfigLens
        - Phalanx\Testing\Lenses\LedgerLens
        - Phalanx\Testing\Lenses\ScopeLens
        - Phalanx\Testing\Lenses\RuntimeLens

parametersSchema:
    phalanxInternalPaths: listOf(string())
    phalanxEnforcedPaths: listOf(string())
    phalanxAuditPaths: listOf(string())
    phalanxRuntimeHookInternalPaths: listOf(string())
    phalanxLifecycleInternalPaths: listOf(string())
    phalanxProcessInternalPaths: listOf(string())
    phalanxCoroutineInternalPaths: listOf(string())
    phalanxTestingPaths: listOf(string())
    phalanxTestingUseTestAppExemptPaths: listOf(string())
    phalanxTestingUseTestScopeExemptPaths: listOf(string())
    phalanxTestingNoRawSleepExemptPaths: listOf(string())
    phalanxTestingLensRequiresBundleExemptPaths: listOf(string())
    phalanxTestingDirectTestAppApplicationExemptPaths: listOf(string())
    phalanxRuntimeNativeLensClasses: listOf(string())

services:
    -
        class: Phalanx\PHPStan\Support\PathPolicy
        arguments:
            - %phalanxInternalPaths%
            - %phalanxEnforcedPaths%
            - %phalanxAuditPaths%

    -
        class: Phalanx\PHPStan\Support\TestingPathPolicy
        arguments:
            - %phalanxTestingPaths%
            - %phalanxTestingUseTestAppExemptPaths%
            - %phalanxTestingUseTestScopeExemptPaths%
            - %phalanxTestingNoRawSleepExemptPaths%
            - %phalanxTestingLensRequiresBundleExemptPaths%
            - %phalanxTestingDirectTestAppApplicationExemptPaths%

    -
        class: Phalanx\PHPStan\Rules\Migration\RootScopeAliasRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Scope\StaticClosureOnlyRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Scope\TaskFactoryStaticClosureOnlyRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Scope\GenericScopeBagAccessRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Scope\HttpRequestLifecycleServiceAccessRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Cancellation\RawSleepRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Worker\NoClosureBoundaryRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Worker\WorkerTaskOnlyRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Worker\WorkerTaskScopeContractRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
            - @PHPStan\Reflection\ReflectionProvider
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Worker\WorkerTaskSerializableStateRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Transaction\TransactionCallbackScopeRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Cancellation\NoCancelledShortcutRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Runtime\HookOwnershipRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
            - %phalanxRuntimeHookInternalPaths%
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Runtime\LifecycleBoundaryRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
            - %phalanxLifecycleInternalPaths%
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Runtime\RuntimeSidLiteralRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
            - %phalanxLifecycleInternalPaths%
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Runtime\NoGenericLifecycleRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Process\ManagedProcessOnlyRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
            - %phalanxProcessInternalPaths%
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Concurrency\RawCoroutineSpawnRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
            - %phalanxCoroutineInternalPaths%
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Pool\BorrowedValueBoundaryRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Pool\BorrowedValuePromotedPropertyRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Pool\BorrowedValuePublicSurfaceRule
        arguments:
            - @Phalanx\PHPStan\Support\PathPolicy
            - @PHPStan\Reflection\ReflectionProvider
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Testing\UseTestAppRule
        arguments:
            - @Phalanx\PHPStan\Support\TestingPathPolicy
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Testing\DirectTestAppApplicationRule
        arguments:
            - @Phalanx\PHPStan\Support\TestingPathPolicy
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Testing\LensRequiresBundleRule
        arguments:
            - @Phalanx\PHPStan\Support\TestingPathPolicy
            - %phalanxRuntimeNativeLensClasses%
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Testing\UseTestScopeRule
        arguments:
            - @Phalanx\PHPStan\Support\TestingPathPolicy
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Testing\NoRawTestSleepRule
        arguments:
            - @Phalanx\PHPStan\Support\TestingPathPolicy
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Testing\UseBenchmarkHarnessRule
        tags:
            - phpstan.rules.rule

    -
        class: Phalanx\PHPStan\Rules\Scope\UnusedClosureParameterRule
        tags:
            - phpstan.rules.rule
