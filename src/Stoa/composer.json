{
    "name": "phalanx-php/stoa",
    "description": "HTTP server framework for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "http",
        "server",
        "routing",
        "async",
        "fastroute",
        "openswoole"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-stoa",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "guzzlehttp/psr7": "^2.0",
        "nikic/fast-route": "^2.0",
        "openswoole/core": "^26.2",
        "phalanx-php/aegis": "^0.6"
    },
    "suggest": {
        "symfony/runtime": "For Symfony Runtime integration via Stoa::starting()",
        "phalanx-php/hydra": "For worker process parallelism in request handlers"
    },
    "require-dev": {
        "phalanx-php/iris": "^0.6",
        "phpunit/phpunit": "^13.0"
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Stoa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Stoa\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        },
        "phalanx": {
            "bundles": [
                "Phalanx\\Stoa\\Testing\\StoaTestableBundle"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
