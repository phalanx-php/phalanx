#!/usr/bin/env php
<?php

declare(strict_types=1);

namespace Phalanx\DevServer;

use Phalanx\Cancellation\Cancelled;

(static function (): never {
    $autoloadCandidates = [
        __DIR__ . '/../vendor/autoload.php',
        __DIR__ . '/../../../vendor/autoload.php',
        __DIR__ . '/../../../../vendor/autoload.php',
    ];

    $autoloaded = false;

    foreach ($autoloadCandidates as $file) {
        if (file_exists($file)) {
            require $file;
            $autoloaded = true;
            break;
        }
    }

    if (!$autoloaded) {
        fwrite(STDERR, "Could not find autoload.php. Run 'composer install' first.\n");
        exit(1);
    }

    $configFile = getcwd() . '/dev-server.php';

    if (!file_exists($configFile)) {
        fwrite(STDERR, "No dev-server.php found in " . getcwd() . "\n");
        fwrite(STDERR, "Create a dev-server.php that returns a " . DevServerApplicationBuilder::class . " from DevServer::starting().\n");
        exit(1);
    }

    $result = require $configFile;

    if (!$result instanceof DevServerApplicationBuilder) {
        fwrite(STDERR, "dev-server.php must return an instance of " . DevServerApplicationBuilder::class . "\n");
        exit(1);
    }

    try {
        exit($result->run());
    } catch (Cancelled) {
        exit(130);
    }
})();
