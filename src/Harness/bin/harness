#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoload = dirname(__DIR__) . '/vendor/autoload_runtime.php';

if (!is_file($autoload)) {
    $autoload = dirname(__DIR__, 3) . '/vendor/autoload_runtime.php';
}

require_once $autoload;

use Phalanx\Harness\Harness;

return static fn(array $context): \Closure => static fn(): int => Harness::app($context)->run();
