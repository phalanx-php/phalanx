{
    "name": "phalanx-php/ai-providers",
    "description": "Agent abstraction for PHP 8.4+: contracts, provider/transport adapters, conversation parsers, vendor HomeDirs",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "agents",
        "llm",
        "anthropic",
        "openai",
        "gemini",
        "ollama",
        "agent-abstraction",
        "conversation-parser",
        "swoole"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-ai-providers",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "support": {
        "source": "https://github.com/phalanx-php/phalanx-ai-providers"
    },
    "require": {
        "php": "^8.4",
        "phalanx-php/mark": "^0.7",
        "symfony/uid": "^7.0 || ^8.0",
        "symfony/yaml": "^7.0 || ^8.0"
    },
    "suggest": {
        "phalanx-php/runtime": "Required for the Runtime Runtime adapter; enables scope-bound cancellation and cleanup",
        "phalanx-php/agent": "Required for the Agent Provider adapter; bridges Agent activity output to AiProviders cues",
        "phalanx-php/http-client": "Required for the HttpClient Transport adapter; Swoole-native streaming HTTP",
        "phalanx-php/filesystem": "Required for HomeDir parsers; managed file I/O with FilePool",
        "phalanx-php/console": "Required for the ai-providers:agents:scan Console command",
        "ext-sqlite3": "Required for Codex HomeDir sqlite-backed history",
        "ext-swoole": "Required for the HttpClient transport and Runtime runtime",
        "php-collective/toml": "Required for reading Codex config.toml settings; without it Settings operates in no-op mode and asString/asInt/etc. throw"
    },
    "require-dev": {
        "swoole/ide-helper": "^6.0",
        "phalanx-php/runtime": "^0.7",
        "phalanx-php/http-client": "^0.7",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.0",
        "slevomat/coding-standard": "^8.15",
        "squizlabs/php_codesniffer": "^3.10 || ^4.0",
        "php-collective/toml": "^0.1.3"
    },
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.env*",
            "/**/.env*",
            "/.gitattributes",
            "/.github",
            "/.github/**",
            "/.gitignore",
            "/**/.gitignore",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml.dist"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\AiProviders\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\AiProviders\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.7.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
