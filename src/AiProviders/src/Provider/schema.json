{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AiProviders Provider Config",
  "description": "Schema for provider YAML configuration documents loaded by Phalanx\\AiProviders\\Provider\\Loader.",
  "type": "object",
  "required": ["id", "display_name", "models", "capabilities", "transport", "wire_translator"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable provider identifier (e.g. 'anthropic', 'openai', 'ollama')."
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable provider name shown in diagnostics and UIs."
    },
    "models": {
      "type": "array",
      "description": "Models exposed by this provider.",
      "items": {
        "type": "object",
        "required": ["name", "model_id", "aliases", "capabilities"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Canonical model name used as the primary lookup key."
          },
          "model_id": {
            "type": "string",
            "minLength": 1,
            "description": "Vendor's model identifier sent on the wire."
          },
          "aliases": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional short-form names that resolve to this model."
          },
          "capabilities": {
            "$ref": "#/$defs/capabilities"
          },
          "input_pricing": {
            "type": ["number", "null"],
            "description": "USD cost per input token (optional)."
          },
          "output_pricing": {
            "type": ["number", "null"],
            "description": "USD cost per output token (optional)."
          }
        }
      }
    },
    "capabilities": {
      "$ref": "#/$defs/capabilities"
    },
    "transport": {
      "type": "object",
      "required": ["streaming", "cancellable"],
      "additionalProperties": false,
      "description": "Transport requirements for this provider.",
      "properties": {
        "streaming": {
          "type": "boolean",
          "description": "Provider supports streaming responses."
        },
        "cancellable": {
          "type": "boolean",
          "description": "Provider supports in-flight request cancellation."
        },
        "backpressure": {
          "type": "boolean",
          "description": "Transport adapter supports backpressure signalling (optional)."
        },
        "partial_json": {
          "type": "boolean",
          "description": "Adapter can emit partial JSON chunks for structured output (optional)."
        }
      }
    },
    "wire_translator": {
      "type": ["string", "null"],
      "description": "Fully-qualified class name of the Provider implementation. Null when the adapter package is not installed."
    },
    "base_url": {
      "type": "string",
      "format": "uri",
      "description": "Per-provider default base URL. Wire translator constructors use this as their default; an explicit constructor argument still wins."
    },
    "default_headers": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Provider-level static headers merged into every request (e.g. HTTP-Referer for OpenRouter ranking)."
    }
  },
  "$defs": {
    "capabilities": {
      "type": "object",
      "required": ["closed", "custom"],
      "additionalProperties": false,
      "properties": {
        "closed": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Closed-set Capability enum values supported (e.g. 'reasoning', 'tool-use')."
        },
        "custom": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Vendor-specific opaque capability strings."
        }
      }
    }
  }
}
