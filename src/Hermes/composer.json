{
    "name": "phalanx-php/hermes",
    "description": "Native WebSocket server and client for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "websocket",
        "ws",
        "client",
        "server",
        "swoole"
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-hermes",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "support": {
        "source": "https://github.com/phalanx-php/phalanx-hermes"
    },
    "require": {
        "php": "^8.4",
        "ext-swoole": "^6.0",
        "phalanx-php/aegis": "^0.6",
        "phalanx-php/stoa": "^0.6",
        "phalanx-php/styx": "^0.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "archive": {
        "exclude": [
            "/.aimind",
            "/.aimind/**",
            "/.claude",
            "/.claude/**",
            "/.daemon8",
            "/.daemon8/**",
            "/.DS_Store",
            "/.env*",
            "/**/.env*",
            "/.gitattributes",
            "/.github",
            "/.github/**",
            "/.gitignore",
            "/**/.gitignore",
            "/.idea",
            "/.idea/**",
            "/.php-cs-fixer.cache",
            "/.phpstan-cache",
            "/.phpstan-cache/**",
            "/.phpunit.result.cache",
            "/brand",
            "/brand/**",
            "/demos",
            "/demos/**",
            "/docs",
            "/docs/**",
            "/examples",
            "/examples/**",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/phpunit.xml.dist",
            "/rector.php",
            "/SPEC.md",
            "/tests",
            "/tests/**",
            "/tmp",
            "/tmp/**",
            "/tools",
            "/tools/**",
            "/vendor",
            "/vendor/**"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=512M vendor/bin/phpunit -c phpunit.xml.dist"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Hermes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Hermes\\Tests\\": "tests/",
            "Phalanx\\Hermes\\Client\\Tests\\": "tests/Client/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.6.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
