{
    "name": "phalanx-php/phalanx",
    "description": "Expression-based async coordination for PHP 8.4+ (monorepo)",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "type": "project",
    "require": {
        "php": "^8.4",
        "mlocati/ip-lib": "^1.22",
        "nikic/fast-route": "^2.0",
        "openswoole/core": "^26.2",
        "league/commonmark": "^2.7",
        "symfony/console": "^7.0 || ^8.0",
        "symfony/dotenv": "^7.0 || ^8.0",
        "symfony/process": "^7.0 || ^8.0",
        "symfony/uid": "^7.0 || ^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "guzzlehttp/guzzle": "^7.10",
        "hyperf/guzzle": "^3.1",
        "openswoole/ide-helper": "^26.2",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.0",
        "rector/swiss-knife": "^2.3",
        "slevomat/coding-standard": "^8.15",
        "spatie/ignition": "^1.15",
        "squizlabs/php_codesniffer": "^3.10 || ^4.0",
        "symfony/runtime": "^7.0 || ^8.0",
        "yosymfony/toml": "^1.0"
    },
    "autoload": {
        "files": [
            "framework/src/Theatron/src/Ui/functions.php"
        ],
        "psr-4": {
            "Phalanx\\": "framework/src/Aegis/src/",
            "Phalanx\\Archon\\": "framework/src/Archon/src/",
            "Phalanx\\Stoa\\": "framework/src/Stoa/src/",
            "Phalanx\\Iris\\": "framework/src/Iris/src/",
            "Phalanx\\Hydra\\": "framework/src/Hydra/src/",
            "Phalanx\\Styx\\": "framework/src/Styx/src/",
            "Phalanx\\Athena\\": "framework/src/Athena/src/",

            "Phalanx\\Surreal\\": "framework/src/Surreal/src/",
            "Phalanx\\Theatron\\": "framework/src/Theatron/src/",
            "Phalanx\\Hermes\\": "framework/src/Hermes/src/",
            "Phalanx\\Argos\\": "framework/src/Argos/src/",
            "Phalanx\\Grammata\\": "framework/src/Grammata/src/",
            "Phalanx\\Enigma\\": "framework/src/Enigma/src/",
            "Phalanx\\Eidolon\\": "framework/src/Eidolon/src/",
            "Phalanx\\Panoply\\": "framework/src/Panoply/src/",
            "Phalanx\\PHPStan\\": "framework/src/PHPStan/src/",
            "Phalanx\\Skopos\\": "framework/src/Skopos/src/",
            "Phalanx\\Cli\\": "framework/src/Cli/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Benchmarks\\Kit\\": "benchmarks/_kit/",
            "Phalanx\\Benchmarks\\Http\\": "benchmarks/http/",
            "Phalanx\\Benchmarks\\Kernel\\": "benchmarks/kernel/",
            "Phalanx\\Demos\\Kit\\": "demos/_kit/",
            "Phalanx\\Demos\\Athena\\": "demos/athena/",
            "Phalanx\\Archon\\Tests\\": "framework/src/Archon/tests/",
            "Phalanx\\Tests\\Stoa\\": "framework/src/Stoa/tests/",
            "Phalanx\\Iris\\Tests\\": "framework/src/Iris/tests/",
            "Phalanx\\Hydra\\Tests\\": "framework/src/Hydra/tests/",
            "Phalanx\\Styx\\Tests\\": "framework/src/Styx/tests/",
            "Phalanx\\Tests\\": ["framework/src/Aegis/tests/", "tests/"],
            "Phalanx\\Athena\\Tests\\": "framework/src/Athena/tests/",

            "Phalanx\\Skopos\\Tests\\": "framework/src/Skopos/tests/",
            "Phalanx\\Surreal\\Tests\\": "framework/src/Surreal/tests/",
            "Phalanx\\Demos\\Surreal\\": "demos/surreal/",
            "Phalanx\\Hermes\\Tests\\": "framework/src/Hermes/tests/",
            "Phalanx\\Argos\\Tests\\": "framework/src/Argos/tests/",
            "Phalanx\\Grammata\\Tests\\": "framework/src/Grammata/tests/",
            "Phalanx\\Enigma\\Tests\\": "framework/src/Enigma/tests/",
            "Phalanx\\Panoply\\Tests\\": "framework/src/Panoply/tests/",
            "Phalanx\\PHPStan\\Tests\\": "framework/src/PHPStan/tests/",
            "Phalanx\\Tests\\Eidolon\\": "framework/src/Eidolon/tests/",
            "Phalanx\\Theatron\\Tests\\": "framework/src/Theatron/tests/",
            "Phalanx\\Cli\\Tests\\": "framework/src/Cli/tests/"
        },
        "classmap": [
            "framework/src/Aegis/tests/Support/Fixtures/",
            "framework/src/PHPStan/tests/Rules/Fixtures/",
            "framework/src/PHPStan/tests/Integration/Fixtures/",
            "demos/athena/support-triage/src/",
            "demos/athena/research-agent/src/",
            "demos/hydra/01-basic-workers/src/",
            "demos/hydra/02-structured-parallel/src/",
            "demos/hydra/03-cancellation-fail-fast/src/",
            "demos/archon/01-basic-commands/src/",
            "demos/archon/02-interactive-input/src/",
            "demos/archon/03-supervised-concurrency/src/",
            "demos/archon/04-runtime-lifecycle/src/",
            "demos/stoa/01-basic-routing/src/",
            "demos/stoa/02-api/src/",
            "demos/stoa/03-realtime/src/",
            "demos/stoa/04-runtime-lifecycle/src/"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "framework/src/*"
        }
    ],
    "scripts": {
        "test": "php -d memory_limit=1G vendor/bin/phpunit",
        "test:cli": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Cli/tests/",
        "test:core": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Aegis/tests/",
        "test:aegis": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Aegis/tests/",
        "test:archon": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Archon/tests/",
        "test:argos": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Argos/tests/",
        "test:ai": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Athena/tests/",
        "test:eidolon": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Eidolon/tests/",
        "test:grammata": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Grammata/tests/",
        "test:hermes": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Hermes/tests/",
        "test:hydra": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Hydra/tests/",
        "test:iris": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Iris/tests/",
        "test:panoply": "php -d memory_limit=512M vendor/bin/phpunit -c framework/src/Panoply/phpunit.xml.dist --testsuite=Unit",
        "test:panoply:integration": "php -d memory_limit=512M vendor/bin/phpunit -c framework/src/Panoply/phpunit.xml.dist --testsuite=Integration",
        "test:panoply:acceptance": "php -d memory_limit=512M vendor/bin/phpunit -c framework/src/Panoply/phpunit.xml.dist --testsuite=Acceptance",
        "test:phpstan": "php -d memory_limit=512M vendor/bin/phpunit framework/src/PHPStan/tests/",
        "test:skopos": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Skopos/tests/",
        "test:stoa": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Stoa/tests/",
        "test:styx": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Styx/tests/",
        "test:surreal": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Surreal/tests/",
        "test:ssh": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Enigma/tests/",
        "test:theatron": "php -d memory_limit=512M vendor/bin/phpunit framework/src/Theatron/tests/",
        "analyse": "php vendor/bin/phpstan analyse --memory-limit=512M",
        "audit:runtime-risk": "php framework/src/PHPStan/bin/runtime-risk-audit",
        "rector": "php vendor/bin/rector process",
        "rector:dry": "php vendor/bin/rector process --dry-run",
        "fmt": "php vendor/bin/php-cs-fixer fix --diff",
        "fmt:dry": "php vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs": "php vendor/bin/phpcs --standard=framework/src/Aegis/phpcs.xml",
        "cs:fix": "php vendor/bin/phpcbf --standard=framework/src/Aegis/phpcs.xml",
        "bench:aegis": "php -d memory_limit=512M benchmarks/kernel/run.php",
        "bench:stoa": "php -d memory_limit=512M benchmarks/http/run.php",
        "bench:wrk": "php -d memory_limit=512M benchmarks/http/server.php",
        "demo:aegis": ["@demo:aegis:runtime", "@demo:aegis:supervision", "@demo:aegis:cancellation", "@demo:aegis:singleflight", "@demo:aegis:memory"],
        "demo:aegis:runtime": "php demos/aegis/01-runtime-policy/demo.php",
        "demo:aegis:supervision": "php demos/aegis/02-scope-supervision/demo.php",
        "demo:aegis:cancellation": "php demos/aegis/03-cancellation/demo.php",
        "demo:aegis:singleflight": "php demos/aegis/04-singleflight/demo.php",
        "demo:aegis:memory": "php demos/aegis/05-runtime-memory/demo.php",
        "demo:hydra": ["@demo:hydra:basic", "@demo:hydra:parallel", "@demo:hydra:cancellation"],
        "demo:hydra:basic": "php demos/hydra/01-basic-workers/demo.php",
        "demo:hydra:parallel": "php demos/hydra/02-structured-parallel/demo.php",
        "demo:hydra:cancellation": "php demos/hydra/03-cancellation-fail-fast/demo.php",
        "demo:stoa": ["@demo:stoa:quickstart", "@demo:stoa:api", "@demo:stoa:realtime", "@demo:stoa:runtime"],
        "demo:stoa:quickstart": "php demos/stoa/01-basic-routing/demo.php",
        "demo:stoa:api": "php demos/stoa/02-api/demo.php",
        "demo:stoa:realtime": "php demos/stoa/03-realtime/demo.php",
        "demo:stoa:runtime": "php demos/stoa/04-runtime-lifecycle/demo.php",
        "demo:stoa:errors": "php demos/stoa/05-error-diagnostics/demo.php",
        "demo:stoa:serve:quickstart": "php demos/stoa/01-basic-routing/server.php",
        "demo:stoa:serve:api": "php demos/stoa/02-api/server.php",
        "demo:stoa:serve:realtime": "php demos/stoa/03-realtime/server.php",
        "demo:stoa:serve:runtime": "php demos/stoa/04-runtime-lifecycle/server.php",
        "demo:stoa:serve:errors": "php demos/stoa/05-error-diagnostics/server.php",
        "demo:archon": ["@demo:archon:basic", "@demo:archon:interactive", "@demo:archon:concurrency", "@demo:archon:lifecycle", "@demo:archon:errors"],
        "demo:archon:basic": "php demos/archon/01-basic-commands/demo.php",
        "demo:archon:interactive": "php demos/archon/02-interactive-input/demo.php",
        "demo:archon:concurrency": "php demos/archon/03-supervised-concurrency/demo.php",
        "demo:archon:lifecycle": "php demos/archon/04-runtime-lifecycle/demo.php",
        "demo:archon:errors": ["@demo:archon:errors:basic", "@demo:archon:errors:deep"],
        "demo:archon:errors:basic": "php demos/archon/05-error-diagnostics/demo.php",
        "demo:archon:errors:deep": "php demos/archon/05-error-diagnostics/ultra_deep.php",
        "demo:athena": ["@demo:athena:streaming", "@demo:athena:guzzle", "@demo:athena:mcp-stdio", "@demo:athena:mcp-sse", "@demo:athena:support-triage", "@demo:athena:research-agent"],
        "demo:athena:streaming": "php demos/athena/01-streaming-providers/demo.php",
        "demo:athena:guzzle": "php demos/athena/02-third-party-sdk-alongside-athena/demo.php",
        "demo:athena:mcp-stdio": "php demos/athena/03-mcp-stdio/demo.php",
        "demo:athena:mcp-sse": "php demos/athena/04-mcp-sse/demo.php",
        "demo:athena:support-triage": "php demos/athena/support-triage/demo.php",
        "demo:athena:research-agent": "php demos/athena/research-agent/demo.php",
        "demo:athena:serve:support-triage": "php demos/athena/support-triage/server.php",
        "demo:surreal": ["@demo:surreal:memory", "@demo:surreal:live"],
        "demo:surreal:memory": "php demos/surreal/01-in-memory-rpc/demo.php",
        "demo:surreal:live": "php demos/surreal/02-live-query/demo.php",
        "demo:theatron": "php framework/src/Theatron/demos/full.php",
        "demo:skopos:basic-dev": "php demos/skopos/01-basic-dev/skopos.php",
        "examples:lint": "find demos framework/src/Theatron/demos -name '*.php' -not -path '*/vendor/*' -print0 | xargs -0 -n1 php -l > /dev/null",
        "gen:test-accessors": "php framework/src/Aegis/bin/regenerate-accessors",
        "gen:test-accessors:check": "php framework/src/Aegis/bin/check-accessors-in-sync",
        "post-autoload-dump": "@gen:test-accessors",
        "check": ["@analyse", "@rector:dry", "@fmt:dry", "@cs", "@gen:test-accessors:check", "@test", "@examples:lint"]
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "replace": {
        "phalanx-php/aegis": "self.version",
        "phalanx-php/archon": "self.version",
        "phalanx-php/argos": "self.version",
        "phalanx-php/athena": "self.version",
        "phalanx-php/cli": "self.version",
        "phalanx-php/eidolon": "self.version",
        "phalanx-php/enigma": "self.version",
        "phalanx-php/grammata": "self.version",
        "phalanx-php/hermes": "self.version",
        "phalanx-php/hydra": "self.version",
        "phalanx-php/iris": "self.version",
        "phalanx-php/panoply": "self.version",
        "phalanx-php/phpstan": "self.version",
        "phalanx-php/skopos": "self.version",
        "phalanx-php/stoa": "self.version",
        "phalanx-php/styx": "self.version",
        "phalanx-php/surreal": "self.version",
        "phalanx-php/theatron": "self.version"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
