{
    "name": "phalanx-php/phalanx",
    "description": "Expression-based async coordination for PHP 8.4+ (monorepo)",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "type": "project",
    "require": {
        "php": "^8.4",
        "ext-redis": "*",
        "amphp/amp": "^3.0",
        "amphp/postgres": "^2.2",
        "evenement/evenement": "^3.0",
        "mlocati/ip-lib": "^1.22",
        "nikic/fast-route": "^2.0",
        "openswoole/core": "^26.2",
        "symfony/process": "^7.0",
        "ratchet/rfc6455": "^0.4.0",
        "react/async": "^4.3",
        "react/child-process": "^0.6",
        "react/datagram": "^1.10",
        "react/event-loop": "^1.5",
        "react/http": "^1.10",
        "react/promise": "^3.2",
        "react/promise-timer": "^1.11",
        "react/stream": "^1.4",
        "revolt/event-loop-adapter-react": "^1.1",
        "symfony/uid": "^7.0"
    },
    "require-dev": {
        "clue/docker-react": "^1.6",
        "guzzlehttp/guzzle": "^7.10",
        "hyperf/guzzle": "^3.1",
        "openswoole/ide-helper": "^26.2",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.0",
        "rector/swiss-knife": "^2.3",
        "slevomat/coding-standard": "^8.15",
        "squizlabs/php_codesniffer": "^3.10",
        "symfony/runtime": "^7.0",
        "symplify/monorepo-builder": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\": "packages/phalanx-aegis/src/",
            "Phalanx\\Archon\\": "packages/phalanx-archon/src/",
            "Phalanx\\Stoa\\": "packages/phalanx-stoa/src/",
            "Phalanx\\Iris\\": "packages/phalanx-iris/src/",
            "Phalanx\\Hydra\\": "packages/phalanx-hydra/src/",
            "Phalanx\\Styx\\": "packages/phalanx-styx/src/",
            "Phalanx\\Athena\\": "packages/phalanx-athena/src/",
            "Phalanx\\Postgres\\": "packages/phalanx-postgres/src/",
            "Phalanx\\Redis\\": "packages/phalanx-redis/src/",
            "Phalanx\\Surreal\\": "packages/phalanx-surreal/src/",
            "Phalanx\\Hermes\\": "packages/phalanx-hermes/src/",
            "Phalanx\\Hermes\\Client\\": "packages/phalanx-hermes/src/Client/",
            "Phalanx\\Argos\\": "packages/phalanx-argos/src/",
            "Phalanx\\Grammata\\": "packages/phalanx-grammata/src/",
            "Phalanx\\Enigma\\": "packages/phalanx-enigma/src/",
            "Phalanx\\Eidolon\\": "packages/phalanx-eidolon/src/",
            "Phalanx\\PHPStan\\": "packages/phalanx-phpstan/src/",
            "Phalanx\\Skopos\\": "packages/phalanx-skopos/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Archon\\Tests\\": "packages/phalanx-archon/tests/",
            "Phalanx\\Tests\\Stoa\\": "packages/phalanx-stoa/tests/",
            "Phalanx\\Iris\\Tests\\": "packages/phalanx-iris/tests/",
            "Phalanx\\Hydra\\Tests\\": "packages/phalanx-hydra/tests/",
            "Phalanx\\Styx\\Tests\\": "packages/phalanx-styx/tests/",
            "Phalanx\\Tests\\": ["packages/phalanx-aegis/tests/", "tests/"],
            "Phalanx\\Athena\\Tests\\": "packages/phalanx-athena/tests/",
            "Phalanx\\Postgres\\Tests\\": "packages/phalanx-postgres/tests/",
            "Phalanx\\Redis\\Tests\\": "packages/phalanx-redis/tests/",
            "Phalanx\\Surreal\\Tests\\": "packages/phalanx-surreal/tests/",
            "Phalanx\\Hermes\\Tests\\": "packages/phalanx-hermes/tests/",
            "Phalanx\\Hermes\\Client\\Tests\\": "packages/phalanx-hermes/tests/Client/",
            "Phalanx\\Argos\\Tests\\": "packages/phalanx-argos/tests/",
            "Phalanx\\Grammata\\Tests\\": "packages/phalanx-grammata/tests/",
            "Phalanx\\Enigma\\Tests\\": "packages/phalanx-enigma/tests/",
            "Phalanx\\PHPStan\\Tests\\": "packages/phalanx-phpstan/tests/",
            "Phalanx\\Tests\\Eidolon\\": "packages/phalanx-eidolon/tests/"
        },
        "classmap": [
            "packages/phalanx-aegis/tests/Support/Fixtures/",
            "packages/phalanx-phpstan/tests/Rules/Fixtures/",
            "packages/phalanx-athena/examples/support-triage/src/",
            "packages/phalanx-athena/examples/research-agent/src/",
            "packages/phalanx-athena/examples/multi-tenant-fleet/src/"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*"
        }
    ],
    "scripts": {
        "test": "php vendor/bin/phpunit packages/phalanx-aegis/tests/",
        "test:all": "php vendor/bin/phpunit",
        "test:core": "php vendor/bin/phpunit packages/phalanx-aegis/tests/",
        "test:iris": "php vendor/bin/phpunit packages/phalanx-iris/tests/",
        "test:ai": "php vendor/bin/phpunit packages/phalanx-athena/tests/",
        "test:redis": "php vendor/bin/phpunit packages/phalanx-redis/tests/",
        "test:surreal": "php vendor/bin/phpunit packages/phalanx-surreal/tests/",
        "test:ssh": "php vendor/bin/phpunit packages/phalanx-enigma/tests/",
        "analyse": "php vendor/bin/phpstan analyse --memory-limit=512M",
        "audit:runtime-risk": "php packages/phalanx-phpstan/bin/runtime-risk-audit",
        "rector": "php vendor/bin/rector process",
        "rector:dry": "php vendor/bin/rector process --dry-run",
        "cs": "php vendor/bin/phpcs --standard=packages/phalanx-aegis/phpcs.xml",
        "cs:fix": "php vendor/bin/phpcbf --standard=packages/phalanx-aegis/phpcs.xml",
        "bench:aegis": "php -d memory_limit=512M benchmarks/kernel/run.php",
        "bench:stoa": "php -d memory_limit=512M benchmarks/http/run.php",
        "demo:aegis": ["@demo:aegis:runtime", "@demo:aegis:supervision", "@demo:aegis:cancellation", "@demo:aegis:singleflight", "@demo:aegis:memory"],
        "demo:aegis:runtime": "php packages/phalanx-aegis/examples/01-runtime-policy/demo.php",
        "demo:aegis:supervision": "php packages/phalanx-aegis/examples/02-scope-supervision/demo.php",
        "demo:aegis:cancellation": "php packages/phalanx-aegis/examples/03-cancellation/demo.php",
        "demo:aegis:singleflight": "php packages/phalanx-aegis/examples/04-singleflight/demo.php",
        "demo:aegis:memory": "php packages/phalanx-aegis/examples/05-runtime-memory/demo.php",
        "demo:stoa": ["@demo:stoa:quickstart", "@demo:stoa:api", "@demo:stoa:realtime", "@demo:stoa:runtime"],
        "demo:stoa:quickstart": "php packages/phalanx-stoa/examples/01-basic-routing/demo.php",
        "demo:stoa:api": "php packages/phalanx-stoa/examples/02-api/demo.php",
        "demo:stoa:realtime": "php packages/phalanx-stoa/examples/03-realtime/demo.php",
        "demo:stoa:runtime": "php packages/phalanx-stoa/examples/04-runtime-lifecycle/demo.php",
        "demo:stoa:serve:quickstart": "php packages/phalanx-stoa/examples/01-basic-routing/server.php",
        "demo:stoa:serve:api": "php packages/phalanx-stoa/examples/02-api/server.php",
        "demo:stoa:serve:realtime": "php packages/phalanx-stoa/examples/03-realtime/server.php",
        "demo:stoa:serve:runtime": "php packages/phalanx-stoa/examples/04-runtime-lifecycle/server.php",
        "demo:archon": ["@demo:archon:basic", "@demo:archon:interactive", "@demo:archon:concurrency", "@demo:archon:lifecycle"],
        "demo:archon:basic": "php packages/phalanx-archon/examples/01-basic-commands/demo.php",
        "demo:archon:interactive": "php packages/phalanx-archon/examples/02-interactive-input/demo.php",
        "demo:archon:concurrency": "php packages/phalanx-archon/examples/03-supervised-concurrency/demo.php",
        "demo:archon:lifecycle": "php packages/phalanx-archon/examples/04-runtime-lifecycle/demo.php",
        "demo:athena": ["@demo:athena:streaming", "@demo:athena:worker:fleet"],
        "demo:athena:streaming": "php packages/phalanx-athena/examples/01-streaming-providers/demo.php",
        "demo:athena:guzzle": "php packages/phalanx-athena/examples/02-guzzle-sdk-coexistence/demo.php",
        "demo:athena:serve:support-triage": "php packages/phalanx-athena/examples/support-triage/server.php",
        "demo:athena:serve:research-agent": "php packages/phalanx-athena/examples/research-agent/server.php",
        "demo:athena:serve:fleet-gateway": "php packages/phalanx-athena/examples/multi-tenant-fleet/gateway.php",
        "demo:athena:worker:fleet": "php packages/phalanx-athena/examples/multi-tenant-fleet/worker.php",
        "demo:surreal": ["@demo:surreal:memory"],
        "demo:surreal:memory": "php packages/phalanx-surreal/examples/01-in-memory-rpc/demo.php",
        "examples:lint": "find examples packages/phalanx-aegis/examples packages/phalanx-archon/examples packages/phalanx-athena/examples packages/phalanx-stoa/examples packages/phalanx-surreal/examples -name '*.php' -not -path '*/vendor/*' -print0 | xargs -0 -n1 php -l > /dev/null",
        "check": ["@analyse", "@rector:dry", "@cs", "@test", "@test:redis", "@test:surreal", "@examples:lint"]
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "replace": {
        "phalanx-php/aegis": "0.6.1",
        "phalanx-php/archon": "0.6.1",
        "phalanx-php/argos": "0.6.1",
        "phalanx-php/athena": "0.6.1",
        "phalanx-php/eidolon": "0.6.1",
        "phalanx-php/enigma": "0.6.1",
        "phalanx-php/grammata": "0.6.1",
        "phalanx-php/hermes": "0.6.1",
        "phalanx-php/hydra": "0.6.1",
        "phalanx-php/iris": "0.6.1",
        "phalanx-php/postgres": "0.6.1",
        "phalanx-php/phpstan": "0.6.1",
        "phalanx-php/redis": "0.6.1",
        "phalanx-php/skopos": "0.6.1",
        "phalanx-php/stoa": "0.6.1",
        "phalanx-php/styx": "0.6.1",
        "phalanx-php/surreal": "0.6.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
