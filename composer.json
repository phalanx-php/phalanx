{
    "name": "phalanx/phalanx",
    "description": "Expression-based async coordination for PHP 8.4+ (monorepo)",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@jhavens.tech"
        }
    ],
    "type": "project",
    "require": {
        "php": "^8.4",
        "amphp/amp": "^3.0",
        "amphp/postgres": "^2.2",
        "clue/redis-react": "^2.8",
        "evenement/evenement": "^3.0",
        "nikic/fast-route": "^2.0",
        "ratchet/rfc6455": "^0.4.0",
        "react/async": "^4.3",
        "react/child-process": "^0.6",
        "react/datagram": "^1.10",
        "react/event-loop": "^1.5",
        "react/http": "^1.10",
        "react/promise": "^3.2",
        "react/stream": "^1.4",
        "revolt/event-loop-adapter-react": "^1.1"
    },
    "require-dev": {
        "clue/docker-react": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "react/promise-timer": "^1.11",
        "rector/rector": "^2.0",
        "slevomat/coding-standard": "^8.15",
        "squizlabs/php_codesniffer": "^3.10",
        "symplify/monorepo-builder": "^11.0",
        "wyrihaximus/phpstan-react": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\": "packages/phalanx-core/src/",
            "Phalanx\\Console\\": "packages/phalanx-console/src/",
            "Phalanx\\Http\\": "packages/phalanx-http/src/",
            "Phalanx\\Parallel\\": "packages/phalanx-parallel/src/",
            "Phalanx\\Stream\\": "packages/phalanx-stream/src/",
            "Phalanx\\Twilio\\": "packages/phalanx-twilio/src/",
            "Phalanx\\Ai\\": "packages/phalanx-ai/src/",
            "Phalanx\\Postgres\\": "packages/phalanx-postgres/src/",
            "Phalanx\\Redis\\": "packages/phalanx-redis/src/",
            "Phalanx\\Terminal\\": "packages/phalanx-terminal/src/",
            "Phalanx\\WebSocket\\": "packages/phalanx-websocket/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Console\\Tests\\": "packages/phalanx-console/tests/",
            "Phalanx\\Http\\Tests\\": "packages/phalanx-http/tests/",
            "Phalanx\\Parallel\\Tests\\": "packages/phalanx-parallel/tests/",
            "Phalanx\\Stream\\Tests\\": "packages/phalanx-stream/tests/",
            "Phalanx\\Tests\\": "packages/phalanx-core/tests/",
            "Phalanx\\Twilio\\Tests\\": "packages/phalanx-twilio/tests/",
            "Phalanx\\Ai\\Tests\\": "packages/phalanx-ai/tests/",
            "Phalanx\\Postgres\\Tests\\": "packages/phalanx-postgres/tests/",
            "Phalanx\\Redis\\Tests\\": "packages/phalanx-redis/tests/",
            "Phalanx\\Terminal\\Tests\\": "packages/phalanx-terminal/tests/",
            "Phalanx\\WebSocket\\Tests\\": "packages/phalanx-websocket/tests/"
        },
        "classmap": [
            "packages/phalanx-core/tests/Support/Fixtures/",
            "packages/phalanx-ai/examples/support-triage/src/",
            "packages/phalanx-ai/examples/research-agent/src/",
            "packages/phalanx-ai/examples/multi-tenant-fleet/src/"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*"
        }
    ],
    "scripts": {
        "test": "php vendor/bin/phpunit",
        "test:core": "cd packages/phalanx-core && php vendor/bin/phpunit",
        "test:twilio": "php vendor/bin/phpunit packages/phalanx-twilio/tests/",
        "test:ai": "php vendor/bin/phpunit packages/phalanx-ai/tests/",
        "analyse": "php vendor/bin/phpstan analyse",
        "rector": "php vendor/bin/rector process",
        "rector:dry": "php vendor/bin/rector process --dry-run",
        "cs": "php vendor/bin/phpcs --standard=packages/phalanx-core/phpcs.xml",
        "cs:fix": "php vendor/bin/phpcbf --standard=packages/phalanx-core/phpcs.xml",
        "check": ["@analyse", "@rector:dry", "@test"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "replace": {
        "phalanx/console": "0.1.0",
        "phalanx/core": "0.1.0",
        "phalanx/http": "0.1.0",
        "phalanx/twilio": "0.1.0",
        "phalanx/ai": "0.1.0",
        "phalanx/parallel": "0.1.0",
        "phalanx/postgres": "0.1.0",
        "phalanx/redis": "0.1.0",
        "phalanx/stream": "0.1.0",
        "phalanx/terminal": "0.1.0",
        "phalanx/websocket": "0.1.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
