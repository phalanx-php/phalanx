{
    "name": "phalanx-php/phalanx",
    "description": "Supervised execution framework for PHP 8.4+ on Swoole",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "type": "project",
    "require": {
        "php": "^8.4",
        "mlocati/ip-lib": "^1.22",
        "nikic/fast-route": "^2.0",
        "league/commonmark": "^2.7",
        "symfony/console": "^7.0 || ^8.0",
        "symfony/dotenv": "^7.0 || ^8.0",
        "symfony/process": "^7.0 || ^8.0",
        "symfony/uid": "^7.0 || ^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.10",
        "php-collective/toml": "^0.1.3",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.0",
        "rector/swiss-knife": "^2.3",
        "slevomat/coding-standard": "^8.15",
        "spatie/ignition": "^1.15",
        "squizlabs/php_codesniffer": "^3.10 || ^4.0",
        "swoole/ide-helper": "^6.0",
        "symfony/runtime": "^7.0 || ^8.0"
    },
    "autoload": {
        "files": [
            "src/Theatron/src/Ui/functions.php"
        ],
        "psr-4": {
            "Phalanx\\": "src/Aegis/src/",
            "Phalanx\\Archon\\": "src/Archon/src/",
            "Phalanx\\Argos\\": "src/Argos/src/",
            "Phalanx\\Athena\\": "src/Athena/src/",
            "Phalanx\\Cli\\": "src/Cli/src/",
            "Phalanx\\Enigma\\": "src/Enigma/src/",
            "Phalanx\\Grammata\\": "src/Grammata/src/",
            "Phalanx\\Hermes\\": "src/Hermes/src/",
            "Phalanx\\Hydra\\": "src/Hydra/src/",
            "Phalanx\\Iris\\": "src/Iris/src/",
            "Phalanx\\PHPStan\\": "src/PHPStan/src/",
            "Phalanx\\Panoply\\": "src/Panoply/src/",
            "Phalanx\\Skopos\\": "src/Skopos/src/",
            "Phalanx\\Stoa\\": "src/Stoa/src/",
            "Phalanx\\Styx\\": "src/Styx/src/",
            "Phalanx\\Surreal\\": "src/Surreal/src/",
            "Phalanx\\Theatron\\": "src/Theatron/src/",
            "Phalanx\\Themis\\": "src/Themis/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Benchmarks\\Kit\\": "benchmarks/_kit/",
            "Phalanx\\Benchmarks\\Http\\": "benchmarks/http/",
            "Phalanx\\Benchmarks\\Kernel\\": "benchmarks/kernel/",
            "Phalanx\\Demos\\Kit\\": "demos/_kit/",
            "Phalanx\\Demos\\Athena\\": "demos/athena/",
            "Phalanx\\Demos\\Surreal\\": "demos/surreal/",
            "Phalanx\\Tests\\": "tests/",
            "Phalanx\\Aegis\\Tests\\": "src/Aegis/tests/",
            "Phalanx\\Archon\\Tests\\": "src/Archon/tests/",
            "Phalanx\\Argos\\Tests\\": "src/Argos/tests/",
            "Phalanx\\Athena\\Tests\\": "src/Athena/tests/",
            "Phalanx\\Cli\\Tests\\": "src/Cli/tests/",
            "Phalanx\\Enigma\\Tests\\": "src/Enigma/tests/",
            "Phalanx\\Grammata\\Tests\\": "src/Grammata/tests/",
            "Phalanx\\Hermes\\Tests\\": "src/Hermes/tests/",
            "Phalanx\\Hydra\\Tests\\": "src/Hydra/tests/",
            "Phalanx\\Iris\\Tests\\": "src/Iris/tests/",
            "Phalanx\\PHPStan\\Tests\\": "src/PHPStan/tests/",
            "Phalanx\\Panoply\\Tests\\": "src/Panoply/tests/",
            "Phalanx\\Skopos\\Tests\\": "src/Skopos/tests/",
            "Phalanx\\Stoa\\Tests\\": "src/Stoa/tests/",
            "Phalanx\\Styx\\Tests\\": "src/Styx/tests/",
            "Phalanx\\Surreal\\Tests\\": "src/Surreal/tests/",
            "Phalanx\\Theatron\\Tests\\": "src/Theatron/tests/",
            "Phalanx\\Themis\\Tests\\": "src/Themis/tests/",
            "Phalanx\\Hermes\\Client\\Tests\\": "src/Hermes/tests/Client/"
        },
        "classmap": [
            "src/Aegis/tests/Support/Fixtures/",
            "src/PHPStan/tests/Rules/Fixtures/",
            "src/PHPStan/tests/Integration/Fixtures/",
            "demos/athena/support-triage/src/",
            "demos/athena/research-agent/src/",
            "demos/hydra/01-basic-workers/src/",
            "demos/hydra/02-structured-parallel/src/",
            "demos/hydra/03-cancellation-fail-fast/src/",
            "demos/archon/01-basic-commands/src/",
            "demos/archon/02-interactive-input/src/",
            "demos/archon/03-supervised-concurrency/src/",
            "demos/archon/04-runtime-lifecycle/src/",
            "demos/stoa/01-basic-routing/src/",
            "demos/stoa/02-api/src/",
            "demos/stoa/03-realtime/src/",
            "demos/stoa/04-runtime-lifecycle/src/"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "src/*"
        }
    ],
    "archive": {
        "exclude": [
            "/.aimind",
            "/.claude",
            "/.daemon8",
            "/.DS_Store",
            "/.github",
            "/.idea",
            "/.phpstan-cache",
            "/.phpunit.result.cache",
            "/README.ai-draft.md",
            "/benchmarks",
            "/demos",
            "/docs",
            "/examples",
            "/history.txt",
            "/phpcs.xml",
            "/phpstan.neon",
            "/phpunit.xml",
            "/rector.php",
            "/roadmap",
            "/roadmap/**",
            "/src/*/demos",
            "/src/*/phpunit.xml",
            "/src/*/phpunit.xml.dist",
            "/src/*/tests",
            "/tests",
            "/tmp",
            "/tools",
            "/vendor"
        ]
    },
    "scripts": {
        "test": "php -d memory_limit=1G vendor/bin/phpunit",
        "test:panoply:integration": "php -d memory_limit=512M vendor/bin/phpunit -c src/Panoply/phpunit.xml.dist --testsuite=Integration --do-not-fail-on-empty-test-suite",
        "test:panoply:acceptance": "php -d memory_limit=512M vendor/bin/phpunit -c src/Panoply/phpunit.xml.dist --testsuite=Acceptance",
        "analyse": "php vendor/bin/phpstan analyse --memory-limit=512M",
        "audit:runtime-risk": "php src/PHPStan/bin/runtime-risk-audit",
        "rector": "php vendor/bin/rector process",
        "rector:dry": "php vendor/bin/rector process --dry-run",
        "cs": "php vendor/bin/phpcs --standard=phpcs.xml",
        "cs:fix": "php vendor/bin/phpcbf --standard=phpcs.xml",
        "bench:aegis": "php -d memory_limit=512M benchmarks/kernel/run.php",
        "bench:stoa": "php -d memory_limit=512M benchmarks/http/run.php",
        "bench:wrk": "php -d memory_limit=512M benchmarks/http/server.php",
        "demo:aegis": [
            "@demo:aegis:runtime",
            "@demo:aegis:supervision",
            "@demo:aegis:cancellation",
            "@demo:aegis:singleflight",
            "@demo:aegis:memory"
        ],
        "demo:aegis:runtime": "php demos/aegis/01-runtime-policy/demo.php",
        "demo:aegis:supervision": "php demos/aegis/02-scope-supervision/demo.php",
        "demo:aegis:cancellation": "php demos/aegis/03-cancellation/demo.php",
        "demo:aegis:singleflight": "php demos/aegis/04-singleflight/demo.php",
        "demo:aegis:memory": "php demos/aegis/05-runtime-memory/demo.php",
        "demo:hydra": [
            "@demo:hydra:basic",
            "@demo:hydra:parallel",
            "@demo:hydra:cancellation"
        ],
        "demo:hydra:basic": "php demos/hydra/01-basic-workers/demo.php",
        "demo:hydra:parallel": "php demos/hydra/02-structured-parallel/demo.php",
        "demo:hydra:cancellation": "php demos/hydra/03-cancellation-fail-fast/demo.php",
        "demo:stoa": [
            "@demo:stoa:quickstart",
            "@demo:stoa:api",
            "@demo:stoa:realtime",
            "@demo:stoa:runtime"
        ],
        "demo:stoa:quickstart": "php demos/stoa/01-basic-routing/demo.php",
        "demo:stoa:api": "php demos/stoa/02-api/demo.php",
        "demo:stoa:realtime": "php demos/stoa/03-realtime/demo.php",
        "demo:stoa:runtime": "php demos/stoa/04-runtime-lifecycle/demo.php",
        "demo:stoa:errors": "php demos/stoa/05-error-diagnostics/demo.php",
        "demo:stoa:serve:quickstart": "php demos/stoa/01-basic-routing/server.php",
        "demo:stoa:serve:api": "php demos/stoa/02-api/server.php",
        "demo:stoa:serve:realtime": "php demos/stoa/03-realtime/server.php",
        "demo:stoa:serve:runtime": "php demos/stoa/04-runtime-lifecycle/server.php",
        "demo:stoa:serve:errors": "php demos/stoa/05-error-diagnostics/server.php",
        "demo:archon": [
            "@demo:archon:basic",
            "@demo:archon:interactive",
            "@demo:archon:concurrency",
            "@demo:archon:lifecycle",
            "@demo:archon:errors"
        ],
        "demo:archon:basic": "php demos/archon/01-basic-commands/demo.php",
        "demo:archon:interactive": "php demos/archon/02-interactive-input/demo.php",
        "demo:archon:concurrency": "php demos/archon/03-supervised-concurrency/demo.php",
        "demo:archon:lifecycle": "php demos/archon/04-runtime-lifecycle/demo.php",
        "demo:archon:errors": [
            "@demo:archon:errors:basic",
            "@demo:archon:errors:deep"
        ],
        "demo:archon:errors:basic": "php demos/archon/05-error-diagnostics/demo.php",
        "demo:archon:errors:deep": "php demos/archon/05-error-diagnostics/ultra_deep.php",
        "demo:athena": [
            "@demo:athena:streaming",
            "@demo:athena:guzzle",
            "@demo:athena:mcp-stdio",
            "@demo:athena:mcp-sse",
            "@demo:athena:support-triage",
            "@demo:athena:research-agent"
        ],
        "demo:athena:streaming": "php demos/athena/01-streaming-providers/demo.php",
        "demo:athena:guzzle": "php demos/athena/02-third-party-sdk-alongside-athena/demo.php",
        "demo:athena:mcp-stdio": "php demos/athena/03-mcp-stdio/demo.php",
        "demo:athena:mcp-sse": "php demos/athena/04-mcp-sse/demo.php",
        "demo:athena:support-triage": "php demos/athena/support-triage/demo.php",
        "demo:athena:research-agent": "php demos/athena/research-agent/demo.php",
        "demo:athena:serve:support-triage": "php demos/athena/support-triage/server.php",
        "demo:surreal": [
            "@demo:surreal:memory",
            "@demo:surreal:live"
        ],
        "demo:surreal:memory": "php demos/surreal/01-in-memory-rpc/demo.php",
        "demo:surreal:live": "php demos/surreal/02-live-query/demo.php",
        "demo:skopos:basic-dev": "php demos/skopos/01-basic-dev/skopos.php",
        "examples:lint": "find demos -name '*.php' -not -path '*/vendor/*' -print0 | xargs -0 -n1 php -l > /dev/null",
        "gen:test-accessors": "php src/Aegis/bin/regenerate-accessors",
        "gen:test-accessors:check": "php src/Aegis/bin/check-accessors-in-sync",
        "post-autoload-dump": "@gen:test-accessors",
        "check": [
            "@analyse",
            "@rector:dry",
            "@cs",
            "@gen:test-accessors:check",
            "@test",
            "@examples:lint"
        ],
        "test:aegis": "php -d memory_limit=512M vendor/bin/phpunit -c src/Aegis/phpunit.xml.dist",
        "test:archon": "php -d memory_limit=512M vendor/bin/phpunit -c src/Archon/phpunit.xml",
        "test:argos": "php -d memory_limit=512M vendor/bin/phpunit -c src/Argos/phpunit.xml",
        "test:athena": "php -d memory_limit=512M vendor/bin/phpunit -c src/Athena/phpunit.xml.dist",
        "test:cli": "php -d memory_limit=512M vendor/bin/phpunit -c src/Cli/phpunit.xml.dist",
        "test:enigma": "php -d memory_limit=512M vendor/bin/phpunit -c src/Enigma/phpunit.xml.dist",
        "test:grammata": "php -d memory_limit=512M vendor/bin/phpunit -c src/Grammata/phpunit.xml",
        "test:hermes": "php -d memory_limit=512M vendor/bin/phpunit -c src/Hermes/phpunit.xml.dist",
        "test:hydra": "php -d memory_limit=512M vendor/bin/phpunit -c src/Hydra/phpunit.xml",
        "test:iris": "php -d memory_limit=512M vendor/bin/phpunit -c src/Iris/phpunit.xml.dist",
        "test:phpstan": "php -d memory_limit=512M vendor/bin/phpunit -c src/PHPStan/phpunit.xml.dist",
        "test:panoply": "php -d memory_limit=512M vendor/bin/phpunit -c src/Panoply/phpunit.xml.dist --testsuite=Unit",
        "test:skopos": "php -d memory_limit=512M vendor/bin/phpunit -c src/Skopos/phpunit.xml.dist",
        "test:stoa": "php -d memory_limit=512M vendor/bin/phpunit -c src/Stoa/phpunit.xml",
        "test:styx": "php -d memory_limit=512M vendor/bin/phpunit -c src/Styx/phpunit.xml",
        "test:surreal": "php -d memory_limit=512M vendor/bin/phpunit -c src/Surreal/phpunit.xml.dist",
        "test:theatron": "php -d memory_limit=512M vendor/bin/phpunit -c src/Theatron/phpunit.xml",
        "test:themis": "php -d memory_limit=512M vendor/bin/phpunit -c src/Themis/phpunit.xml"
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "replace": {
        "phalanx-php/aegis": "self.version",
        "phalanx-php/archon": "self.version",
        "phalanx-php/argos": "self.version",
        "phalanx-php/athena": "self.version",
        "phalanx-php/cli": "self.version",
        "phalanx-php/enigma": "self.version",
        "phalanx-php/grammata": "self.version",
        "phalanx-php/hermes": "self.version",
        "phalanx-php/hydra": "self.version",
        "phalanx-php/iris": "self.version",
        "phalanx-php/phpstan": "self.version",
        "phalanx-php/panoply": "self.version",
        "phalanx-php/skopos": "self.version",
        "phalanx-php/stoa": "self.version",
        "phalanx-php/styx": "self.version",
        "phalanx-php/surreal": "self.version",
        "phalanx-php/theatron": "self.version",
        "phalanx-php/themis": "self.version"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
