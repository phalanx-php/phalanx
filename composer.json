{
    "name": "phalanx-php/phalanx",
    "description": "Expression-based async coordination for PHP 8.4+ (monorepo)",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "type": "project",
    "require": {
        "php": "^8.4",
        "ext-redis": "*",
        "mlocati/ip-lib": "^1.22",
        "nikic/fast-route": "^2.0",
        "openswoole/core": "^26.2",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "symfony/uid": "^7.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.10",
        "hyperf/guzzle": "^3.1",
        "openswoole/ide-helper": "^26.2",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.0",
        "rector/swiss-knife": "^2.3",
        "slevomat/coding-standard": "^8.15",
        "spatie/ignition": "^1.15",
        "squizlabs/php_codesniffer": "^3.10",
        "symfony/runtime": "^7.0",
        "symplify/monorepo-builder": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\": "packages/phalanx-aegis/src/",
            "Phalanx\\Archon\\": "packages/phalanx-archon/src/",
            "Phalanx\\Stoa\\": "packages/phalanx-stoa/src/",
            "Phalanx\\Iris\\": "packages/phalanx-iris/src/",
            "Phalanx\\Hydra\\": "packages/phalanx-hydra/src/",
            "Phalanx\\Styx\\": "packages/phalanx-styx/src/",
            "Phalanx\\Athena\\": "packages/phalanx-athena/src/",
            "Phalanx\\Redis\\": "packages/phalanx-redis/src/",
            "Phalanx\\Surreal\\": "packages/phalanx-surreal/src/",
            "Phalanx\\Hermes\\": "packages/phalanx-hermes/src/",
            "Phalanx\\Argos\\": "packages/phalanx-argos/src/",
            "Phalanx\\Grammata\\": "packages/phalanx-grammata/src/",
            "Phalanx\\Enigma\\": "packages/phalanx-enigma/src/",
            "Phalanx\\Eidolon\\": "packages/phalanx-eidolon/src/",
            "Phalanx\\PHPStan\\": "packages/phalanx-phpstan/src/",
            "Phalanx\\Skopos\\": "packages/phalanx-skopos/src/",
            "Phalanx\\Aegis\\Codegen\\": "packages/phalanx-aegis-codegen/src/",
            "Phalanx\\Cli\\": "packages/phalanx-cli/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Demos\\Kit\\": "demos/_kit/",
            "Phalanx\\Demos\\Athena\\": "demos/athena/",
            "Phalanx\\Archon\\Tests\\": "packages/phalanx-archon/tests/",
            "Phalanx\\Tests\\Stoa\\": "packages/phalanx-stoa/tests/",
            "Phalanx\\Iris\\Tests\\": "packages/phalanx-iris/tests/",
            "Phalanx\\Hydra\\Tests\\": "packages/phalanx-hydra/tests/",
            "Phalanx\\Styx\\Tests\\": "packages/phalanx-styx/tests/",
            "Phalanx\\Tests\\": ["packages/phalanx-aegis/tests/", "tests/"],
            "Phalanx\\Athena\\Tests\\": "packages/phalanx-athena/tests/",
            "Phalanx\\Redis\\Tests\\": "packages/phalanx-redis/tests/",
            "Phalanx\\Skopos\\Tests\\": "packages/phalanx-skopos/tests/",
            "Phalanx\\Surreal\\Tests\\": "packages/phalanx-surreal/tests/",
            "Phalanx\\Demos\\Surreal\\": "demos/surreal/",
            "Phalanx\\Hermes\\Tests\\": "packages/phalanx-hermes/tests/",
            "Phalanx\\Argos\\Tests\\": "packages/phalanx-argos/tests/",
            "Phalanx\\Grammata\\Tests\\": "packages/phalanx-grammata/tests/",
            "Phalanx\\Enigma\\Tests\\": "packages/phalanx-enigma/tests/",
            "Phalanx\\PHPStan\\Tests\\": "packages/phalanx-phpstan/tests/",
            "Phalanx\\Tests\\Eidolon\\": "packages/phalanx-eidolon/tests/",
            "Phalanx\\Aegis\\Codegen\\Tests\\": "packages/phalanx-aegis-codegen/tests/",
            "Phalanx\\Cli\\Tests\\": "packages/phalanx-cli/tests/"
        },
        "classmap": [
            "packages/phalanx-aegis/tests/Support/Fixtures/",
            "packages/phalanx-phpstan/tests/Rules/Fixtures/",
            "packages/phalanx-phpstan/tests/Integration/Fixtures/",
            "demos/athena/support-triage/src/",
            "demos/athena/research-agent/src/",
            "demos/hydra/01-basic-workers/src/",
            "demos/hydra/02-structured-parallel/src/",
            "demos/hydra/03-cancellation-fail-fast/src/",
            "demos/archon/01-basic-commands/src/",
            "demos/archon/02-interactive-input/src/",
            "demos/archon/03-supervised-concurrency/src/",
            "demos/archon/04-runtime-lifecycle/src/",
            "demos/stoa/01-basic-routing/src/",
            "demos/stoa/02-api/src/",
            "demos/stoa/03-realtime/src/",
            "demos/stoa/04-runtime-lifecycle/src/"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*"
        }
    ],
    "scripts": {
        "test": "@test:all",
        "test:all": [
            "@test:aegis",
            "@test:aegis-codegen",
            "@test:archon",
            "@test:argos",
            "@test:ai",
            "@test:cli",
            "@test:eidolon",
            "@test:ssh",
            "@test:grammata",
            "@test:hermes",
            "@test:hydra",
            "@test:iris",
            "@test:phpstan",
            "@test:redis",
            "@test:skopos",
            "@test:stoa",
            "@test:styx",
            "@test:surreal"
        ],
        "test:cli": "php vendor/bin/phpunit packages/phalanx-cli/tests/",
        "test:core": "php vendor/bin/phpunit packages/phalanx-aegis/tests/",
        "test:aegis": "php vendor/bin/phpunit packages/phalanx-aegis/tests/",
        "test:aegis-codegen": "php vendor/bin/phpunit packages/phalanx-aegis-codegen/tests/",
        "test:archon": "php vendor/bin/phpunit packages/phalanx-archon/tests/",
        "test:argos": "php vendor/bin/phpunit packages/phalanx-argos/tests/",
        "test:ai": "php vendor/bin/phpunit packages/phalanx-athena/tests/",
        "test:eidolon": "php vendor/bin/phpunit packages/phalanx-eidolon/tests/",
        "test:grammata": "php vendor/bin/phpunit packages/phalanx-grammata/tests/",
        "test:hermes": "php vendor/bin/phpunit packages/phalanx-hermes/tests/",
        "test:hydra": "php vendor/bin/phpunit packages/phalanx-hydra/tests/",
        "test:iris": "php vendor/bin/phpunit packages/phalanx-iris/tests/",
        "test:phpstan": "php vendor/bin/phpunit packages/phalanx-phpstan/tests/",
        "test:redis": "php vendor/bin/phpunit packages/phalanx-redis/tests/",
        "test:skopos": "php vendor/bin/phpunit packages/phalanx-skopos/tests/",
        "test:stoa": "php vendor/bin/phpunit packages/phalanx-stoa/tests/",
        "test:styx": "php vendor/bin/phpunit packages/phalanx-styx/tests/",
        "test:surreal": "php vendor/bin/phpunit packages/phalanx-surreal/tests/",
        "test:ssh": "php vendor/bin/phpunit packages/phalanx-enigma/tests/",
        "analyse": "php vendor/bin/phpstan analyse --memory-limit=512M",
        "audit:runtime-risk": "php packages/phalanx-phpstan/bin/runtime-risk-audit",
        "rector": "php vendor/bin/rector process",
        "rector:dry": "php vendor/bin/rector process --dry-run",
        "cs": "php vendor/bin/phpcs --standard=packages/phalanx-aegis/phpcs.xml",
        "cs:fix": "php vendor/bin/phpcbf --standard=packages/phalanx-aegis/phpcs.xml",
        "bench:aegis": "php -d memory_limit=512M benchmarks/kernel/run.php",
        "bench:stoa": "php -d memory_limit=512M benchmarks/http/run.php",
        "demo:aegis": ["@demo:aegis:runtime", "@demo:aegis:supervision", "@demo:aegis:cancellation", "@demo:aegis:singleflight", "@demo:aegis:memory"],
        "demo:aegis:runtime": "php demos/aegis/01-runtime-policy/demo.php",
        "demo:aegis:supervision": "php demos/aegis/02-scope-supervision/demo.php",
        "demo:aegis:cancellation": "php demos/aegis/03-cancellation/demo.php",
        "demo:aegis:singleflight": "php demos/aegis/04-singleflight/demo.php",
        "demo:aegis:memory": "php demos/aegis/05-runtime-memory/demo.php",
        "demo:hydra": ["@demo:hydra:basic", "@demo:hydra:parallel", "@demo:hydra:cancellation"],
        "demo:hydra:basic": "php demos/hydra/01-basic-workers/demo.php",
        "demo:hydra:parallel": "php demos/hydra/02-structured-parallel/demo.php",
        "demo:hydra:cancellation": "php demos/hydra/03-cancellation-fail-fast/demo.php",
        "demo:stoa": ["@demo:stoa:quickstart", "@demo:stoa:api", "@demo:stoa:realtime", "@demo:stoa:runtime"],
        "demo:stoa:quickstart": "php demos/stoa/01-basic-routing/demo.php",
        "demo:stoa:api": "php demos/stoa/02-api/demo.php",
        "demo:stoa:realtime": "php demos/stoa/03-realtime/demo.php",
        "demo:stoa:runtime": "php demos/stoa/04-runtime-lifecycle/demo.php",
        "demo:stoa:serve:quickstart": "php demos/stoa/01-basic-routing/server.php",
        "demo:stoa:serve:api": "php demos/stoa/02-api/server.php",
        "demo:stoa:serve:realtime": "php demos/stoa/03-realtime/server.php",
        "demo:stoa:serve:runtime": "php demos/stoa/04-runtime-lifecycle/server.php",
        "demo:archon": ["@demo:archon:basic", "@demo:archon:interactive", "@demo:archon:concurrency", "@demo:archon:lifecycle"],
        "demo:archon:basic": "php demos/archon/01-basic-commands/demo.php",
        "demo:archon:interactive": "php demos/archon/02-interactive-input/demo.php",
        "demo:archon:concurrency": "php demos/archon/03-supervised-concurrency/demo.php",
        "demo:archon:lifecycle": "php demos/archon/04-runtime-lifecycle/demo.php",
        "demo:athena": ["@demo:athena:streaming"],
        "demo:athena:streaming": "php demos/athena/01-streaming-providers/demo.php",
        "demo:athena:guzzle": "php demos/athena/02-guzzle-sdk-coexistence/demo.php",
        "demo:athena:serve:support-triage": "php demos/athena/support-triage/server.php",
        "demo:surreal": ["@demo:surreal:memory", "@demo:surreal:live"],
        "demo:surreal:memory": "php demos/surreal/01-in-memory-rpc/demo.php",
        "demo:surreal:live": "php demos/surreal/02-live-query/demo.php",
        "demo:skopos:basic-dev": "php demos/skopos/01-basic-dev/skopos.php",
        "examples:lint": "find demos -name '*.php' -not -path '*/vendor/*' -print0 | xargs -0 -n1 php -l > /dev/null",
        "gen:test-accessors": "php packages/phalanx-aegis-codegen/bin/regenerate-accessors",
        "gen:test-accessors:check": "php packages/phalanx-aegis-codegen/bin/check-accessors-in-sync",
        "post-autoload-dump": "@gen:test-accessors",
        "check": ["@analyse", "@rector:dry", "@cs", "@gen:test-accessors:check", "@test", "@examples:lint"]
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phalanx-php/aegis-codegen": true
        }
    },
    "replace": {
        "phalanx-php/aegis": "0.6.1",
        "phalanx-php/aegis-codegen": "0.6.1",
        "phalanx-php/archon": "0.6.1",
        "phalanx-php/argos": "0.6.1",
        "phalanx-php/athena": "0.6.1",
        "phalanx-php/eidolon": "0.6.1",
        "phalanx-php/enigma": "0.6.1",
        "phalanx-php/grammata": "0.6.1",
        "phalanx-php/hermes": "0.6.1",
        "phalanx-php/hydra": "0.6.1",
        "phalanx-php/iris": "0.6.1",
        "phalanx-php/phpstan": "0.6.1",
        "phalanx-php/redis": "0.6.1",
        "phalanx-php/skopos": "0.6.1",
        "phalanx-php/stoa": "0.6.1",
        "phalanx-php/styx": "0.6.1",
        "phalanx-php/cli": "0.6.1",
        "phalanx-php/surreal": "0.6.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
