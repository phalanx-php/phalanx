{
    "name": "phalanx-php/phalanx",
    "description": "Expression-based async coordination for PHP 8.4+ (monorepo)",
    "license": "MIT",
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "type": "project",
    "require": {
        "php": "^8.4",
        "amphp/amp": "^3.0",
        "amphp/postgres": "^2.2",
        "clue/redis-react": "^2.8",
        "evenement/evenement": "^3.0",
        "mlocati/ip-lib": "^1.22",
        "nikic/fast-route": "^2.0",
        "ratchet/rfc6455": "^0.4.0",
        "react/async": "^4.3",
        "react/child-process": "^0.6",
        "react/datagram": "^1.10",
        "react/event-loop": "^1.5",
        "react/http": "^1.10",
        "react/promise": "^3.2",
        "react/promise-timer": "^1.11",
        "react/stream": "^1.4",
        "revolt/event-loop-adapter-react": "^1.1"
    },
    "require-dev": {
        "clue/docker-react": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0",
        "rector/swiss-knife": "^2.3",
        "slevomat/coding-standard": "^8.15",
        "squizlabs/php_codesniffer": "^3.10",
        "symplify/monorepo-builder": "^11.0",
        "wyrihaximus/phpstan-react": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\": "packages/phalanx-aegis/src/",
            "Phalanx\\Archon\\": "packages/phalanx-archon/src/",
            "Phalanx\\Stoa\\": "packages/phalanx-stoa/src/",
            "Phalanx\\Hydra\\": "packages/phalanx-hydra/src/",
            "Phalanx\\Styx\\": "packages/phalanx-styx/src/",
            "Phalanx\\Twilio\\": "packages/phalanx-twilio/src/",
            "Phalanx\\Athena\\": "packages/phalanx-athena/src/",
            "Phalanx\\Postgres\\": "packages/phalanx-postgres/src/",
            "Phalanx\\Redis\\": "packages/phalanx-redis/src/",
            "Phalanx\\Theatron\\": "packages/phalanx-theatron/src/",
            "Phalanx\\Hermes\\": "packages/phalanx-hermes/src/",
            "Phalanx\\Hermes\\Client\\": "packages/phalanx-hermes/src/Client/",
            "Phalanx\\Argos\\": "packages/phalanx-argos/src/",
            "Phalanx\\Grammata\\": "packages/phalanx-grammata/src/",
            "Phalanx\\Enigma\\": "packages/phalanx-enigma/src/",
            "Phalanx\\Eidolon\\": "packages/phalanx-eidolon/src/",
            "Phalanx\\Skopos\\": "packages/phalanx-skopos/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Archon\\Tests\\": "packages/phalanx-archon/tests/",
            "Phalanx\\Tests\\Stoa\\": "packages/phalanx-stoa/tests/",
            "Phalanx\\Hydra\\Tests\\": "packages/phalanx-hydra/tests/",
            "Phalanx\\Styx\\Tests\\": "packages/phalanx-styx/tests/",
            "Phalanx\\Tests\\": ["packages/phalanx-aegis/tests/", "tests/"],
            "Phalanx\\Twilio\\Tests\\": "packages/phalanx-twilio/tests/",
            "Phalanx\\Athena\\Tests\\": "packages/phalanx-athena/tests/",
            "Phalanx\\Postgres\\Tests\\": "packages/phalanx-postgres/tests/",
            "Phalanx\\Redis\\Tests\\": "packages/phalanx-redis/tests/",
            "Phalanx\\Theatron\\Tests\\": "packages/phalanx-theatron/tests/",
            "Phalanx\\Hermes\\Tests\\": "packages/phalanx-hermes/tests/",
            "Phalanx\\Hermes\\Client\\Tests\\": "packages/phalanx-hermes/tests/Client/",
            "Phalanx\\Argos\\Tests\\": "packages/phalanx-argos/tests/",
            "Phalanx\\Grammata\\Tests\\": "packages/phalanx-grammata/tests/",
            "Phalanx\\Enigma\\Tests\\": "packages/phalanx-enigma/tests/",
            "Phalanx\\Tests\\Eidolon\\": "packages/phalanx-eidolon/tests/"
        },
        "classmap": [
            "packages/phalanx-aegis/tests/Support/Fixtures/",
            "packages/phalanx-athena/examples/support-triage/src/",
            "packages/phalanx-athena/examples/research-agent/src/",
            "packages/phalanx-athena/examples/multi-tenant-fleet/src/"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*"
        }
    ],
    "scripts": {
        "test": "php vendor/bin/phpunit",
        "test:core": "cd packages/phalanx-aegis && php vendor/bin/phpunit",
        "test:twilio": "php vendor/bin/phpunit packages/phalanx-twilio/tests/",
        "test:ai": "php vendor/bin/phpunit packages/phalanx-athena/tests/",
        "test:ssh": "php vendor/bin/phpunit packages/phalanx-enigma/tests/",
        "analyse": "php vendor/bin/phpstan analyse",
        "rector": "php vendor/bin/rector process",
        "rector:dry": "php vendor/bin/rector process --dry-run",
        "cs": "php vendor/bin/phpcs --standard=packages/phalanx-aegis/phpcs.xml",
        "cs:fix": "php vendor/bin/phpcbf --standard=packages/phalanx-aegis/phpcs.xml",
        "examples:lint": "find examples packages/phalanx-athena/examples -name '*.php' -not -path '*/vendor/*' -print0 | xargs -0 -n1 php -l > /dev/null",
        "check": ["@analyse", "@rector:dry", "@test", "@examples:lint"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "replace": {
        "phalanx-php/aegis": "0.6.1",
        "phalanx-php/archon": "0.6.1",
        "phalanx-php/argos": "0.6.1",
        "phalanx-php/athena": "0.6.1",
        "phalanx-php/eidolon": "0.6.1",
        "phalanx-php/enigma": "0.6.1",
        "phalanx-php/grammata": "0.6.1",
        "phalanx-php/hermes": "0.6.1",
        "phalanx-php/hydra": "0.6.1",
        "phalanx-php/postgres": "0.6.1",
        "phalanx-php/redis": "0.6.1",
        "phalanx-php/skopos": "0.6.1",
        "phalanx-php/stoa": "0.6.1",
        "phalanx-php/styx": "0.6.1",
        "phalanx-php/theatron": "0.6.1",
        "phalanx-php/twilio": "0.6.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
