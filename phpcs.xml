<?xml version="1.0"?>
<ruleset name="Phalanx">
    <file>src/Aegis/src</file>
    <file>src/Agora/src</file>
    <file>src/Archon/src</file>
    <file>src/Argos/src</file>
    <file>src/Athena/src</file>
    <file>src/Cli/src</file>
    <file>src/Dory/src</file>
    <file>src/Eidolon/src</file>
    <file>src/Enigma/src</file>
    <file>src/Grammata/src</file>
    <file>src/Hermes/src</file>
    <file>src/Hydra/src</file>
    <file>src/Iris/src</file>
    <file>src/PHPStan/src</file>
    <file>src/Panoply/src</file>
    <file>src/Skopos/src</file>
    <file>src/Stoa/src</file>
    <file>src/Styx/src</file>
    <file>src/Surreal/src</file>
    <file>src/Theatron/src</file>
    <arg name="colors"/>
    <arg name="warning-severity" value="0"/>
    <arg value="sp"/>

    <!-- PSR-12 base -->
    <rule ref="PSR12">
        <exclude name="PSR1.Classes.ClassDeclaration.MultipleClasses"/>
        <!-- PHP 8.4 property hooks: phpcs parser doesn't understand { get => } syntax -->
        <exclude name="PSR2.Classes.PropertyDeclaration.Multiple"/>
        <exclude name="PSR2.Classes.PropertyDeclaration.ScopeMissing"/>
    </rule>

    <!-- PHP 8.4 property hooks: interface property hooks trigger false positives -->
    <rule ref="Internal.ParseError.InterfaceHasMemberVar">
        <severity>0</severity>
    </rule>

    <!-- PHP 8.4 property hooks: Slevomat doesn't understand hooked properties vs regular properties -->
    <rule ref="SlevomatCodingStandard.Classes.ClassStructure.IncorrectGroupOrder">
        <exclude-pattern>*/SettlementBag.php</exclude-pattern>
        <exclude-pattern>*/ExecutionScope.php</exclude-pattern>
        <exclude-pattern>*/DeferredScope.php</exclude-pattern>
        <exclude-pattern>*/CancellationToken.php</exclude-pattern>
        <exclude-pattern>*/ExecutionContext.php</exclude-pattern>
        <exclude-pattern>*/CommandResult.php</exclude-pattern>
        <exclude-pattern>*/Reactive/Signal.php</exclude-pattern>
        <exclude-pattern>*/Reactive/Computed.php</exclude-pattern>
        <exclude-pattern>*/Component/MountedComponent.php</exclude-pattern>
        <exclude-pattern>*/Focus/FocusManager.php</exclude-pattern>
    </rule>

    <!-- PHP 8.4 property hooks: spacing rules misfire on hook syntax -->
    <rule ref="PSR2.Classes.PropertyDeclaration.SpacingAfterType">
        <exclude-pattern>*/SettlementBag.php</exclude-pattern>
        <exclude-pattern>*/ExecutionContext.php</exclude-pattern>
        <exclude-pattern>*/CommandResult.php</exclude-pattern>
        <exclude-pattern>*/Reactive/Signal.php</exclude-pattern>
        <exclude-pattern>*/Reactive/Computed.php</exclude-pattern>
        <exclude-pattern>*/Component/MountedComponent.php</exclude-pattern>
        <exclude-pattern>*/Focus/FocusManager.php</exclude-pattern>
        <exclude-pattern>*/ScriptContext.php</exclude-pattern>
    </rule>

    <!-- PHP 8.4 property hooks: indentation rule misfires on hook bodies -->
    <rule ref="Generic.WhiteSpace.ScopeIndent.IncorrectExact">
        <exclude-pattern>*/ExecutionContext.php</exclude-pattern>
        <exclude-pattern>*/Reactive/Computed.php</exclude-pattern>
    </rule>

    <!-- Slevomat: Member ordering -->
    <rule ref="SlevomatCodingStandard.Classes.ClassStructure">
        <properties>
            <property name="groups" type="array">
                <element value="uses"/>
                <element value="enum cases"/>
                <element value="public constants"/>
                <element value="protected constants"/>
                <element value="private constants"/>
                <element value="public static properties"/>
                <element value="public properties"/>
                <element value="protected static properties"/>
                <element value="protected properties"/>
                <element value="private static properties"/>
                <element value="private properties"/>
                <element value="constructor"/>
                <element value="static constructors"/>
                <element value="magic methods"/>
                <element value="destructor"/>
                <element value="public static final methods"/>
                <element value="public static abstract methods"/>
                <element value="public static methods"/>
                <element value="public final methods"/>
                <element value="public abstract methods"/>
                <element value="public methods"/>
                <element value="protected static final methods"/>
                <element value="protected static abstract methods"/>
                <element value="protected static methods"/>
                <element value="protected final methods"/>
                <element value="protected abstract methods"/>
                <element value="protected methods"/>
                <element value="private static methods"/>
                <element value="private methods"/>
            </property>
        </properties>
    </rule>

    <rule ref="SlevomatCodingStandard.Namespaces.AlphabeticallySortedUses"/>

    <rule ref="SlevomatCodingStandard.Namespaces.UnusedUses">
        <properties>
            <property name="searchAnnotations" value="true"/>
        </properties>
    </rule>

    <rule ref="SlevomatCodingStandard.TypeHints.DeclareStrictTypes">
        <properties>
            <property name="spacesCountAroundEqualsSign" value="0"/>
        </properties>
    </rule>

    <rule ref="SlevomatCodingStandard.Variables.UnusedVariable">
        <properties>
            <property name="ignoreUnusedValuesWhenOnlyKeysAreUsedInForeach" value="true"/>
        </properties>
    </rule>
</ruleset>
