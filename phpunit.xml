<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         failOnRisky="true"
         failOnWarning="true">
    <php>
        <var name="DAEMON8_BASE_URL" value="http://127.0.0.1:9077"/>
        <var name="DAEMON8_SDK_PATH" value=""/>
    </php>
    <groups>
        <exclude>
            <group>daemon</group>
            <group>live</group>
        </exclude>
    </groups>
    <testsuites>
        <testsuite name="Core Unit">
            <directory>framework/src/Aegis/tests/Unit</directory>
        </testsuite>
        <testsuite name="Core Integration">
            <directory>framework/src/Aegis/tests/Integration</directory>
        </testsuite>
        <testsuite name="Core Smoke">
            <directory>framework/src/Aegis/tests/Smoke</directory>
        </testsuite>
        <testsuite name="Core Resilience">
            <directory>framework/src/Aegis/tests/Resilience</directory>
        </testsuite>
        <testsuite name="Styx Unit">
            <directory>framework/src/Styx/tests/Unit</directory>
        </testsuite>
        <testsuite name="Styx Integration">
            <directory>framework/src/Styx/tests/Integration</directory>
        </testsuite>
        <testsuite name="Archon Unit">
            <directory>framework/src/Archon/tests/Unit</directory>
        </testsuite>
        <testsuite name="Archon Integration">
            <directory>framework/src/Archon/tests/Integration</directory>
        </testsuite>
        <testsuite name="Stoa Unit">
            <directory>framework/src/Stoa/tests/Unit</directory>
        </testsuite>
        <testsuite name="Iris Unit">
            <directory>framework/src/Iris/tests/Unit</directory>
        </testsuite>
        <testsuite name="Iris Integration">
            <directory>framework/src/Iris/tests/Integration</directory>
        </testsuite>
        <testsuite name="Hydra Unit">
            <directory>framework/src/Hydra/tests/Unit</directory>
        </testsuite>
        <testsuite name="Hydra Integration">
            <directory>framework/src/Hydra/tests/Integration</directory>
        </testsuite>
        <testsuite name="Hermes Unit">
            <directory>framework/src/Hermes/tests/Unit</directory>
        </testsuite>
        <testsuite name="Hermes Integration">
            <directory>framework/src/Hermes/tests/Integration</directory>
        </testsuite>
        <testsuite name="Hermes Client Unit">
            <directory>framework/src/Hermes/tests/Client/Unit</directory>
        </testsuite>
        <testsuite name="Athena Unit">
            <directory>framework/src/Athena/tests/Unit</directory>
        </testsuite>
        <testsuite name="Athena Integration">
            <directory>framework/src/Athena/tests/Integration</directory>
        </testsuite>
        <testsuite name="Enigma Unit">
            <directory>framework/src/Enigma/tests/Unit</directory>
        </testsuite>
        <testsuite name="Surreal Unit">
            <directory>framework/src/Surreal/tests/Unit</directory>
        </testsuite>
        <testsuite name="Eidolon Unit">
            <directory>framework/src/Eidolon/tests/Unit</directory>
        </testsuite>
        <testsuite name="Grammata Unit">
            <directory>framework/src/Grammata/tests/Unit</directory>
        </testsuite>
        <testsuite name="Argos Unit">
            <directory>framework/src/Argos/tests/Unit</directory>
        </testsuite>
        <testsuite name="Skopos">
            <directory>framework/src/Skopos/tests</directory>
        </testsuite>
        <testsuite name="CLI Unit">
            <directory>framework/src/Cli/tests/Unit</directory>
        </testsuite>
        <testsuite name="CLI Integration">
            <directory>framework/src/Cli/tests/Integration</directory>
        </testsuite>
        <testsuite name="Architecture">
            <directory>tests/Architecture</directory>
        </testsuite>
        <testsuite name="PHPStan Extension">
            <directory>framework/src/PHPStan/tests</directory>
        </testsuite>
        <testsuite name="Theatron">
            <directory>framework/src/Theatron/tests</directory>
        </testsuite>
        <!-- Keep Stoa's HTTP-lens integration last. OpenSwoole does not fully
             reset its event-loop state inside one PHPUnit process. -->
        <testsuite name="Stoa Integration">
            <directory>framework/src/Stoa/tests/Integration</directory>
        </testsuite>
    </testsuites>
</phpunit>
