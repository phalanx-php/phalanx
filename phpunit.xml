<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         failOnRisky="true"
         failOnWarning="true">
    <php>
        <var name="DAEMON8_BASE_URL" value="http://127.0.0.1:9077"/>
        <var name="DAEMON8_SDK_PATH" value=""/>
    </php>
    <groups>
        <exclude>
            <group>daemon</group>
            <group>live</group>
        </exclude>
    </groups>
    <testsuites>
        <testsuite name="Core Unit">
            <directory>packages/phalanx-aegis/tests/Unit</directory>
        </testsuite>
        <testsuite name="Core Integration">
            <directory>packages/phalanx-aegis/tests/Integration</directory>
        </testsuite>
        <testsuite name="Core Smoke">
            <directory>packages/phalanx-aegis/tests/Smoke</directory>
        </testsuite>
        <testsuite name="Core Resilience">
            <directory>packages/phalanx-aegis/tests/Resilience</directory>
        </testsuite>
        <testsuite name="Styx Unit">
            <directory>packages/phalanx-styx/tests/Unit</directory>
        </testsuite>
        <testsuite name="Styx Integration">
            <directory>packages/phalanx-styx/tests/Integration</directory>
        </testsuite>
        <testsuite name="Archon Unit">
            <directory>packages/phalanx-archon/tests/Unit</directory>
        </testsuite>
        <testsuite name="Archon Integration">
            <directory>packages/phalanx-archon/tests/Integration</directory>
        </testsuite>
        <testsuite name="Stoa Unit">
            <directory>packages/phalanx-stoa/tests/Unit</directory>
        </testsuite>
        <testsuite name="Stoa Integration">
            <directory>packages/phalanx-stoa/tests/Integration</directory>
        </testsuite>
        <testsuite name="Iris Unit">
            <directory>packages/phalanx-iris/tests/Unit</directory>
        </testsuite>
        <testsuite name="Iris Integration">
            <directory>packages/phalanx-iris/tests/Integration</directory>
        </testsuite>
        <testsuite name="Hydra Unit">
            <directory>packages/phalanx-hydra/tests/Unit</directory>
        </testsuite>
        <testsuite name="Hydra Integration">
            <directory>packages/phalanx-hydra/tests/Integration</directory>
        </testsuite>
        <testsuite name="Hermes Unit">
            <directory>packages/phalanx-hermes/tests/Unit</directory>
        </testsuite>
        <testsuite name="Hermes Integration">
            <directory>packages/phalanx-hermes/tests/Integration</directory>
        </testsuite>
        <testsuite name="Hermes Client Unit">
            <directory>packages/phalanx-hermes/tests/Client/Unit</directory>
        </testsuite>
        <testsuite name="Athena Unit">
            <directory>packages/phalanx-athena/tests/Unit</directory>
        </testsuite>
        <testsuite name="Athena Integration">
            <directory>packages/phalanx-athena/tests/Integration</directory>
        </testsuite>
        <testsuite name="Eidolon Unit">
            <directory>packages/phalanx-eidolon/tests/Unit</directory>
        </testsuite>
        <testsuite name="Architecture">
            <directory>tests/Architecture</directory>
        </testsuite>
        <testsuite name="PHPStan Extension">
            <directory>packages/phalanx-phpstan/tests</directory>
        </testsuite>
    </testsuites>
</phpunit>
