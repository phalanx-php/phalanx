.*
*.md

# Default deny: all hidden files/dirs and markdown

# Explicit includes
!.gitignore
!.gitattributes
!.github/
!.env.example
!.php-cs-fixer.php
!.php-cs-fixer.dist.php
.php-cs-fixer.cache
!README.md
!roadmap/**/*.md
roadmap/**/AGENTS.md
roadmap/**/CLAUDE.md
roadmap/**/RTK.md

# Dependencies
vendor/
node_modules/
/src/*/composer.lock
.v2-reference/

# Build artifacts
/build/
dist/
coverage/
target/

# Logs
*.log

# Benchmark outputs
benchmarks/results/*.json
benchmarks/results/*.csv
benchmarks/results/current-*/
