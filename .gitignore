# Default deny: all hidden files/dirs and markdown
.*
*.md

# Explicit includes
!.gitignore
!.gitattributes
!.github/
!.env.example
!.php-cs-fixer.php
.php-cs-fixer.cache
!README.md

# Dependencies
vendor/
node_modules/

# Build artifacts
/build/
dist/
coverage/

# Logs
*.log

# Benchmark outputs
benchmarks/results/*.json
benchmarks/results/*.csv
benchmarks/results/current-*/
