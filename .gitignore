# Default deny: all hidden files/dirs and markdown
.*
*.md

# Explicit includes
!.gitignore
!.github/
!.env.example
!README.md

# Dependencies
vendor/
node_modules/

# Build artifacts
build/
dist/
coverage/

# Logs
*.log

# Benchmark outputs
benchmarks/results/*.json
benchmarks/results/*.csv
benchmarks/results/current-*/
